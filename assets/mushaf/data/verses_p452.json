[{"id":3942,"verse_key":"37:154","text_uthmani":"مَا لَكُمْ كَيْفَ تَحْكُمُونَ"},{"id":3943,"verse_key":"37:155","text_uthmani":"أَفَلَا تَذَكَّرُونَ"},{"id":3944,"verse_key":"37:156","text_uthmani":"أَمْ لَكُمْ سُلْطَـٰنٌ مُّبِينٌ"},{"id":3945,"verse_key":"37:157","text_uthmani":"فَأْتُوا۟ بِكِتَـٰبِكُمْ إِن كُنتُمْ صَـٰدِقِينَ"},{"id":3946,"verse_key":"37:158","text_uthmani":"وَجَعَلُوا۟ بَيْنَهُۥ وَبَيْنَ ٱلْجِنَّةِ نَسَبًا ۚ وَلَقَدْ عَلِمَتِ ٱلْجِنَّةُ إِنَّهُمْ لَمُحْضَرُونَ"},{"id":3947,"verse_key":"37:159","text_uthmani":"سُبْحَـٰنَ ٱللَّهِ عَمَّا يَصِفُونَ"},{"id":3948,"verse_key":"37:160","text_uthmani":"إِلَّا عِبَادَ ٱللَّهِ ٱلْمُخْلَصِينَ"},{"id":3949,"verse_key":"37:161","text_uthmani":"فَإِنَّكُمْ وَمَا تَعْبُدُونَ"},{"id":3950,"verse_key":"37:162","text_uthmani":"مَآ أَنتُمْ عَلَيْهِ بِفَـٰتِنِينَ"},{"id":3951,"verse_key":"37:163","text_uthmani":"إِلَّا مَنْ هُوَ صَالِ ٱلْجَحِيمِ"},{"id":3952,"verse_key":"37:164","text_uthmani":"وَمَا مِنَّآ إِلَّا لَهُۥ مَقَامٌ مَّعْلُومٌ"},{"id":3953,"verse_key":"37:165","text_uthmani":"وَإِنَّا لَنَحْنُ ٱلصَّآفُّونَ"},{"id":3954,"verse_key":"37:166","text_uthmani":"وَإِنَّا لَنَحْنُ ٱلْمُسَبِّحُونَ"},{"id":3955,"verse_key":"37:167","text_uthmani":"وَإِن كَانُوا۟ لَيَقُولُونَ"},{"id":3956,"verse_key":"37:168","text_uthmani":"لَوْ أَنَّ عِندَنَا ذِكْرًا مِّنَ ٱلْأَوَّلِينَ"},{"id":3957,"verse_key":"37:169","text_uthmani":"لَكُنَّا عِبَادَ ٱللَّهِ ٱلْمُخْلَصِينَ"},{"id":3958,"verse_key":"37:170","text_uthmani":"فَكَفَرُوا۟ بِهِۦ ۖ فَسَوْفَ يَعْلَمُونَ"},{"id":3959,"verse_key":"37:171","text_uthmani":"وَلَقَدْ سَبَقَتْ كَلِمَتُنَا لِعِبَادِنَا ٱلْمُرْسَلِينَ"},{"id":3960,"verse_key":"37:172","text_uthmani":"إِنَّهُمْ لَهُمُ ٱلْمَنصُورُونَ"},{"id":3961,"verse_key":"37:173","text_uthmani":"وَإِنَّ جُندَنَا لَهُمُ ٱلْغَـٰلِبُونَ"},{"id":3962,"verse_key":"37:174","text_uthmani":"فَتَوَلَّ عَنْهُمْ حَتَّىٰ حِينٍ"},{"id":3963,"verse_key":"37:175","text_uthmani":"وَأَبْصِرْهُمْ فَسَوْفَ يُبْصِرُونَ"},{"id":3964,"verse_key":"37:176","text_uthmani":"أَفَبِعَذَابِنَا يَسْتَعْجِلُونَ"},{"id":3965,"verse_key":"37:177","text_uthmani":"فَإِذَا نَزَلَ بِسَاحَتِهِمْ فَسَآءَ صَبَاحُ ٱلْمُنذَرِينَ"},{"id":3966,"verse_key":"37:178","text_uthmani":"وَتَوَلَّ عَنْهُمْ حَتَّىٰ حِينٍ"},{"id":3967,"verse_key":"37:179","text_uthmani":"وَأَبْصِرْ فَسَوْفَ يُبْصِرُونَ"},{"id":3968,"verse_key":"37:180","text_uthmani":"سُبْحَـٰنَ رَبِّكَ رَبِّ ٱلْعِزَّةِ عَمَّا يَصِفُونَ"},{"id":3969,"verse_key":"37:181","text_uthmani":"وَسَلَـٰمٌ عَلَى ٱلْمُرْسَلِينَ"},{"id":3970,"verse_key":"37:182","text_uthmani":"وَٱلْحَمْدُ لِلَّهِ رَبِّ ٱلْعَـٰلَمِينَ"}]