[{"id":5617,"verse_key":"76:26","text_uthmani":"وَمِنَ ٱلَّيْلِ فَٱسْجُدْ لَهُۥ وَسَبِّحْهُ لَيْلًا طَوِيلًا"},{"id":5618,"verse_key":"76:27","text_uthmani":"إِنَّ هَـٰٓؤُلَآءِ يُحِبُّونَ ٱلْعَاجِلَةَ وَيَذَرُونَ وَرَآءَهُمْ يَوْمًا ثَقِيلًا"},{"id":5619,"verse_key":"76:28","text_uthmani":"نَّحْنُ خَلَقْنَـٰهُمْ وَشَدَدْنَآ أَسْرَهُمْ ۖ وَإِذَا شِئْنَا بَدَّلْنَآ أَمْثَـٰلَهُمْ تَبْدِيلًا"},{"id":5620,"verse_key":"76:29","text_uthmani":"إِنَّ هَـٰذِهِۦ تَذْكِرَةٌ ۖ فَمَن شَآءَ ٱتَّخَذَ إِلَىٰ رَبِّهِۦ سَبِيلًا"},{"id":5621,"verse_key":"76:30","text_uthmani":"وَمَا تَشَآءُونَ إِلَّآ أَن يَشَآءَ ٱللَّهُ ۚ إِنَّ ٱللَّهَ كَانَ عَلِيمًا حَكِيمًا"},{"id":5622,"verse_key":"76:31","text_uthmani":"يُدْخِلُ مَن يَشَآءُ فِى رَحْمَتِهِۦ ۚ وَٱلظَّـٰلِمِينَ أَعَدَّ لَهُمْ عَذَابًا أَلِيمًۢا"},{"id":5623,"verse_key":"77:1","text_uthmani":" وَٱلْمُرْسَلَـٰتِ عُرْفًا"},{"id":5624,"verse_key":"77:2","text_uthmani":"فَٱلْعَـٰصِفَـٰتِ عَصْفًا"},{"id":5625,"verse_key":"77:3","text_uthmani":"وَٱلنَّـٰشِرَٰتِ نَشْرًا"},{"id":5626,"verse_key":"77:4","text_uthmani":"فَٱلْفَـٰرِقَـٰتِ فَرْقًا"},{"id":5627,"verse_key":"77:5","text_uthmani":"فَٱلْمُلْقِيَـٰتِ ذِكْرًا"},{"id":5628,"verse_key":"77:6","text_uthmani":"عُذْرًا أَوْ نُذْرًا"},{"id":5629,"verse_key":"77:7","text_uthmani":"إِنَّمَا تُوعَدُونَ لَوَٰقِعٌ"},{"id":5630,"verse_key":"77:8","text_uthmani":"فَإِذَا ٱلنُّجُومُ طُمِسَتْ"},{"id":5631,"verse_key":"77:9","text_uthmani":"وَإِذَا ٱلسَّمَآءُ فُرِجَتْ"},{"id":5632,"verse_key":"77:10","text_uthmani":"وَإِذَا ٱلْجِبَالُ نُسِفَتْ"},{"id":5633,"verse_key":"77:11","text_uthmani":"وَإِذَا ٱلرُّسُلُ أُقِّتَتْ"},{"id":5634,"verse_key":"77:12","text_uthmani":"لِأَىِّ يَوْمٍ أُجِّلَتْ"},{"id":5635,"verse_key":"77:13","text_uthmani":"لِيَوْمِ ٱلْفَصْلِ"},{"id":5636,"verse_key":"77:14","text_uthmani":"وَمَآ أَدْرَىٰكَ مَا يَوْمُ ٱلْفَصْلِ"},{"id":5637,"verse_key":"77:15","text_uthmani":"وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ"},{"id":5638,"verse_key":"77:16","text_uthmani":"أَلَمْ نُهْلِكِ ٱلْأَوَّلِينَ"},{"id":5639,"verse_key":"77:17","text_uthmani":"ثُمَّ نُتْبِعُهُمُ ٱلْـَٔاخِرِينَ"},{"id":5640,"verse_key":"77:18","text_uthmani":"كَذَٰلِكَ نَفْعَلُ بِٱلْمُجْرِمِينَ"},{"id":5641,"verse_key":"77:19","text_uthmani":"وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ"}]