[{"id":4918,"verse_key":"55:17","text_uthmani":"رَبُّ ٱلْمَشْرِقَيْنِ وَرَبُّ ٱلْمَغْرِبَيْنِ"},{"id":4919,"verse_key":"55:18","text_uthmani":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"id":4920,"verse_key":"55:19","text_uthmani":"مَرَجَ ٱلْبَحْرَيْنِ يَلْتَقِيَانِ"},{"id":4921,"verse_key":"55:20","text_uthmani":"بَيْنَهُمَا بَرْزَخٌ لَّا يَبْغِيَانِ"},{"id":4922,"verse_key":"55:21","text_uthmani":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"id":4923,"verse_key":"55:22","text_uthmani":"يَخْرُجُ مِنْهُمَا ٱللُّؤْلُؤُ وَٱلْمَرْجَانُ"},{"id":4924,"verse_key":"55:23","text_uthmani":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"id":4925,"verse_key":"55:24","text_uthmani":"وَلَهُ ٱلْجَوَارِ ٱلْمُنشَـَٔاتُ فِى ٱلْبَحْرِ كَٱلْأَعْلَـٰمِ"},{"id":4926,"verse_key":"55:25","text_uthmani":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"id":4927,"verse_key":"55:26","text_uthmani":"كُلُّ مَنْ عَلَيْهَا فَانٍ"},{"id":4928,"verse_key":"55:27","text_uthmani":"وَيَبْقَىٰ وَجْهُ رَبِّكَ ذُو ٱلْجَلَـٰلِ وَٱلْإِكْرَامِ"},{"id":4929,"verse_key":"55:28","text_uthmani":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"id":4930,"verse_key":"55:29","text_uthmani":"يَسْـَٔلُهُۥ مَن فِى ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضِ ۚ كُلَّ يَوْمٍ هُوَ فِى شَأْنٍ"},{"id":4931,"verse_key":"55:30","text_uthmani":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"id":4932,"verse_key":"55:31","text_uthmani":"سَنَفْرُغُ لَكُمْ أَيُّهَ ٱلثَّقَلَانِ"},{"id":4933,"verse_key":"55:32","text_uthmani":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"id":4934,"verse_key":"55:33","text_uthmani":"يَـٰمَعْشَرَ ٱلْجِنِّ وَٱلْإِنسِ إِنِ ٱسْتَطَعْتُمْ أَن تَنفُذُوا۟ مِنْ أَقْطَارِ ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضِ فَٱنفُذُوا۟ ۚ لَا تَنفُذُونَ إِلَّا بِسُلْطَـٰنٍ"},{"id":4935,"verse_key":"55:34","text_uthmani":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"id":4936,"verse_key":"55:35","text_uthmani":"يُرْسَلُ عَلَيْكُمَا شُوَاظٌ مِّن نَّارٍ وَنُحَاسٌ فَلَا تَنتَصِرَانِ"},{"id":4937,"verse_key":"55:36","text_uthmani":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"id":4938,"verse_key":"55:37","text_uthmani":"فَإِذَا ٱنشَقَّتِ ٱلسَّمَآءُ فَكَانَتْ وَرْدَةً كَٱلدِّهَانِ"},{"id":4939,"verse_key":"55:38","text_uthmani":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"id":4940,"verse_key":"55:39","text_uthmani":"فَيَوْمَئِذٍ لَّا يُسْـَٔلُ عَن ذَنۢبِهِۦٓ إِنسٌ وَلَا جَآنٌّ"},{"id":4941,"verse_key":"55:40","text_uthmani":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"}]