[{"id":3116,"verse_key":"26:184","text_uthmani":"وَٱتَّقُوا۟ ٱلَّذِى خَلَقَكُمْ وَٱلْجِبِلَّةَ ٱلْأَوَّلِينَ"},{"id":3117,"verse_key":"26:185","text_uthmani":"قَالُوٓا۟ إِنَّمَآ أَنتَ مِنَ ٱلْمُسَحَّرِينَ"},{"id":3118,"verse_key":"26:186","text_uthmani":"وَمَآ أَنتَ إِلَّا بَشَرٌ مِّثْلُنَا وَإِن نَّظُنُّكَ لَمِنَ ٱلْكَـٰذِبِينَ"},{"id":3119,"verse_key":"26:187","text_uthmani":"فَأَسْقِطْ عَلَيْنَا كِسَفًا مِّنَ ٱلسَّمَآءِ إِن كُنتَ مِنَ ٱلصَّـٰدِقِينَ"},{"id":3120,"verse_key":"26:188","text_uthmani":"قَالَ رَبِّىٓ أَعْلَمُ بِمَا تَعْمَلُونَ"},{"id":3121,"verse_key":"26:189","text_uthmani":"فَكَذَّبُوهُ فَأَخَذَهُمْ عَذَابُ يَوْمِ ٱلظُّلَّةِ ۚ إِنَّهُۥ كَانَ عَذَابَ يَوْمٍ عَظِيمٍ"},{"id":3122,"verse_key":"26:190","text_uthmani":"إِنَّ فِى ذَٰلِكَ لَـَٔايَةً ۖ وَمَا كَانَ أَكْثَرُهُم مُّؤْمِنِينَ"},{"id":3123,"verse_key":"26:191","text_uthmani":"وَإِنَّ رَبَّكَ لَهُوَ ٱلْعَزِيزُ ٱلرَّحِيمُ"},{"id":3124,"verse_key":"26:192","text_uthmani":"وَإِنَّهُۥ لَتَنزِيلُ رَبِّ ٱلْعَـٰلَمِينَ"},{"id":3125,"verse_key":"26:193","text_uthmani":"نَزَلَ بِهِ ٱلرُّوحُ ٱلْأَمِينُ"},{"id":3126,"verse_key":"26:194","text_uthmani":"عَلَىٰ قَلْبِكَ لِتَكُونَ مِنَ ٱلْمُنذِرِينَ"},{"id":3127,"verse_key":"26:195","text_uthmani":"بِلِسَانٍ عَرَبِىٍّ مُّبِينٍ"},{"id":3128,"verse_key":"26:196","text_uthmani":"وَإِنَّهُۥ لَفِى زُبُرِ ٱلْأَوَّلِينَ"},{"id":3129,"verse_key":"26:197","text_uthmani":"أَوَلَمْ يَكُن لَّهُمْ ءَايَةً أَن يَعْلَمَهُۥ عُلَمَـٰٓؤُا۟ بَنِىٓ إِسْرَٰٓءِيلَ"},{"id":3130,"verse_key":"26:198","text_uthmani":"وَلَوْ نَزَّلْنَـٰهُ عَلَىٰ بَعْضِ ٱلْأَعْجَمِينَ"},{"id":3131,"verse_key":"26:199","text_uthmani":"فَقَرَأَهُۥ عَلَيْهِم مَّا كَانُوا۟ بِهِۦ مُؤْمِنِينَ"},{"id":3132,"verse_key":"26:200","text_uthmani":"كَذَٰلِكَ سَلَكْنَـٰهُ فِى قُلُوبِ ٱلْمُجْرِمِينَ"},{"id":3133,"verse_key":"26:201","text_uthmani":"لَا يُؤْمِنُونَ بِهِۦ حَتَّىٰ يَرَوُا۟ ٱلْعَذَابَ ٱلْأَلِيمَ"},{"id":3134,"verse_key":"26:202","text_uthmani":"فَيَأْتِيَهُم بَغْتَةً وَهُمْ لَا يَشْعُرُونَ"},{"id":3135,"verse_key":"26:203","text_uthmani":"فَيَقُولُوا۟ هَلْ نَحْنُ مُنظَرُونَ"},{"id":3136,"verse_key":"26:204","text_uthmani":"أَفَبِعَذَابِنَا يَسْتَعْجِلُونَ"},{"id":3137,"verse_key":"26:205","text_uthmani":"أَفَرَءَيْتَ إِن مَّتَّعْنَـٰهُمْ سِنِينَ"},{"id":3138,"verse_key":"26:206","text_uthmani":"ثُمَّ جَآءَهُم مَّا كَانُوا۟ يُوعَدُونَ"}]