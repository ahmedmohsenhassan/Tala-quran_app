[{"id":4942,"verse_key":"55:41","text_uthmani":"يُعْرَفُ ٱلْمُجْرِمُونَ بِسِيمَـٰهُمْ فَيُؤْخَذُ بِٱلنَّوَٰصِى وَٱلْأَقْدَامِ"},{"id":4943,"verse_key":"55:42","text_uthmani":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"id":4944,"verse_key":"55:43","text_uthmani":"هَـٰذِهِۦ جَهَنَّمُ ٱلَّتِى يُكَذِّبُ بِهَا ٱلْمُجْرِمُونَ"},{"id":4945,"verse_key":"55:44","text_uthmani":"يَطُوفُونَ بَيْنَهَا وَبَيْنَ حَمِيمٍ ءَانٍ"},{"id":4946,"verse_key":"55:45","text_uthmani":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"id":4947,"verse_key":"55:46","text_uthmani":"وَلِمَنْ خَافَ مَقَامَ رَبِّهِۦ جَنَّتَانِ"},{"id":4948,"verse_key":"55:47","text_uthmani":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"id":4949,"verse_key":"55:48","text_uthmani":"ذَوَاتَآ أَفْنَانٍ"},{"id":4950,"verse_key":"55:49","text_uthmani":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"id":4951,"verse_key":"55:50","text_uthmani":"فِيهِمَا عَيْنَانِ تَجْرِيَانِ"},{"id":4952,"verse_key":"55:51","text_uthmani":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"id":4953,"verse_key":"55:52","text_uthmani":"فِيهِمَا مِن كُلِّ فَـٰكِهَةٍ زَوْجَانِ"},{"id":4954,"verse_key":"55:53","text_uthmani":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"id":4955,"verse_key":"55:54","text_uthmani":"مُتَّكِـِٔينَ عَلَىٰ فُرُشٍۭ بَطَآئِنُهَا مِنْ إِسْتَبْرَقٍ ۚ وَجَنَى ٱلْجَنَّتَيْنِ دَانٍ"},{"id":4956,"verse_key":"55:55","text_uthmani":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"id":4957,"verse_key":"55:56","text_uthmani":"فِيهِنَّ قَـٰصِرَٰتُ ٱلطَّرْفِ لَمْ يَطْمِثْهُنَّ إِنسٌ قَبْلَهُمْ وَلَا جَآنٌّ"},{"id":4958,"verse_key":"55:57","text_uthmani":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"id":4959,"verse_key":"55:58","text_uthmani":"كَأَنَّهُنَّ ٱلْيَاقُوتُ وَٱلْمَرْجَانُ"},{"id":4960,"verse_key":"55:59","text_uthmani":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"id":4961,"verse_key":"55:60","text_uthmani":"هَلْ جَزَآءُ ٱلْإِحْسَـٰنِ إِلَّا ٱلْإِحْسَـٰنُ"},{"id":4962,"verse_key":"55:61","text_uthmani":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"id":4963,"verse_key":"55:62","text_uthmani":"وَمِن دُونِهِمَا جَنَّتَانِ"},{"id":4964,"verse_key":"55:63","text_uthmani":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"id":4965,"verse_key":"55:64","text_uthmani":"مُدْهَآمَّتَانِ"},{"id":4966,"verse_key":"55:65","text_uthmani":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"id":4967,"verse_key":"55:66","text_uthmani":"فِيهِمَا عَيْنَانِ نَضَّاخَتَانِ"},{"id":4968,"verse_key":"55:67","text_uthmani":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"}]