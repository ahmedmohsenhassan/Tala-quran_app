[{"id":6194,"verse_key":"106:1","text_uthmani":" لِإِيلَـٰفِ قُرَيْشٍ"},{"id":6195,"verse_key":"106:2","text_uthmani":"إِۦلَـٰفِهِمْ رِحْلَةَ ٱلشِّتَآءِ وَٱلصَّيْفِ"},{"id":6196,"verse_key":"106:3","text_uthmani":"فَلْيَعْبُدُوا۟ رَبَّ هَـٰذَا ٱلْبَيْتِ"},{"id":6197,"verse_key":"106:4","text_uthmani":"ٱلَّذِىٓ أَطْعَمَهُم مِّن جُوعٍ وَءَامَنَهُم مِّنْ خَوْفٍۭ"},{"id":6198,"verse_key":"107:1","text_uthmani":" أَرَءَيْتَ ٱلَّذِى يُكَذِّبُ بِٱلدِّينِ"},{"id":6199,"verse_key":"107:2","text_uthmani":"فَذَٰلِكَ ٱلَّذِى يَدُعُّ ٱلْيَتِيمَ"},{"id":6200,"verse_key":"107:3","text_uthmani":"وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلْمِسْكِينِ"},{"id":6201,"verse_key":"107:4","text_uthmani":"فَوَيْلٌ لِّلْمُصَلِّينَ"},{"id":6202,"verse_key":"107:5","text_uthmani":"ٱلَّذِينَ هُمْ عَن صَلَاتِهِمْ سَاهُونَ"},{"id":6203,"verse_key":"107:6","text_uthmani":"ٱلَّذِينَ هُمْ يُرَآءُونَ"},{"id":6204,"verse_key":"107:7","text_uthmani":"وَيَمْنَعُونَ ٱلْمَاعُونَ"},{"id":6205,"verse_key":"108:1","text_uthmani":" إِنَّآ أَعْطَيْنَـٰكَ ٱلْكَوْثَرَ"},{"id":6206,"verse_key":"108:2","text_uthmani":"فَصَلِّ لِرَبِّكَ وَٱنْحَرْ"},{"id":6207,"verse_key":"108:3","text_uthmani":"إِنَّ شَانِئَكَ هُوَ ٱلْأَبْتَرُ"}]