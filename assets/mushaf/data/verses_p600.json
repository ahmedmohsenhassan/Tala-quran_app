[{"id":6156,"verse_key":"100:10","text_uthmani":"وَحُصِّلَ مَا فِى ٱلصُّدُورِ"},{"id":6157,"verse_key":"100:11","text_uthmani":"إِنَّ رَبَّهُم بِهِمْ يَوْمَئِذٍ لَّخَبِيرٌۢ"},{"id":6158,"verse_key":"101:1","text_uthmani":" ٱلْقَارِعَةُ"},{"id":6159,"verse_key":"101:2","text_uthmani":"مَا ٱلْقَارِعَةُ"},{"id":6160,"verse_key":"101:3","text_uthmani":"وَمَآ أَدْرَىٰكَ مَا ٱلْقَارِعَةُ"},{"id":6161,"verse_key":"101:4","text_uthmani":"يَوْمَ يَكُونُ ٱلنَّاسُ كَٱلْفَرَاشِ ٱلْمَبْثُوثِ"},{"id":6162,"verse_key":"101:5","text_uthmani":"وَتَكُونُ ٱلْجِبَالُ كَٱلْعِهْنِ ٱلْمَنفُوشِ"},{"id":6163,"verse_key":"101:6","text_uthmani":"فَأَمَّا مَن ثَقُلَتْ مَوَٰزِينُهُۥ"},{"id":6164,"verse_key":"101:7","text_uthmani":"فَهُوَ فِى عِيشَةٍ رَّاضِيَةٍ"},{"id":6165,"verse_key":"101:8","text_uthmani":"وَأَمَّا مَنْ خَفَّتْ مَوَٰزِينُهُۥ"},{"id":6166,"verse_key":"101:9","text_uthmani":"فَأُمُّهُۥ هَاوِيَةٌ"},{"id":6167,"verse_key":"101:10","text_uthmani":"وَمَآ أَدْرَىٰكَ مَا هِيَهْ"},{"id":6168,"verse_key":"101:11","text_uthmani":"نَارٌ حَامِيَةٌۢ"},{"id":6169,"verse_key":"102:1","text_uthmani":" أَلْهَىٰكُمُ ٱلتَّكَاثُرُ"},{"id":6170,"verse_key":"102:2","text_uthmani":"حَتَّىٰ زُرْتُمُ ٱلْمَقَابِرَ"},{"id":6171,"verse_key":"102:3","text_uthmani":"كَلَّا سَوْفَ تَعْلَمُونَ"},{"id":6172,"verse_key":"102:4","text_uthmani":"ثُمَّ كَلَّا سَوْفَ تَعْلَمُونَ"},{"id":6173,"verse_key":"102:5","text_uthmani":"كَلَّا لَوْ تَعْلَمُونَ عِلْمَ ٱلْيَقِينِ"},{"id":6174,"verse_key":"102:6","text_uthmani":"لَتَرَوُنَّ ٱلْجَحِيمَ"},{"id":6175,"verse_key":"102:7","text_uthmani":"ثُمَّ لَتَرَوُنَّهَا عَيْنَ ٱلْيَقِينِ"},{"id":6176,"verse_key":"102:8","text_uthmani":"ثُمَّ لَتُسْـَٔلُنَّ يَوْمَئِذٍ عَنِ ٱلنَّعِيمِ"}]