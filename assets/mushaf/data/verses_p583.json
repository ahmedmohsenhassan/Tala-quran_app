[{"id":5703,"verse_key":"78:31","text_uthmani":"إِنَّ لِلْمُتَّقِينَ مَفَازًا"},{"id":5704,"verse_key":"78:32","text_uthmani":"حَدَآئِقَ وَأَعْنَـٰبًا"},{"id":5705,"verse_key":"78:33","text_uthmani":"وَكَوَاعِبَ أَتْرَابًا"},{"id":5706,"verse_key":"78:34","text_uthmani":"وَكَأْسًا دِهَاقًا"},{"id":5707,"verse_key":"78:35","text_uthmani":"لَّا يَسْمَعُونَ فِيهَا لَغْوًا وَلَا كِذَّٰبًا"},{"id":5708,"verse_key":"78:36","text_uthmani":"جَزَآءً مِّن رَّبِّكَ عَطَآءً حِسَابًا"},{"id":5709,"verse_key":"78:37","text_uthmani":"رَّبِّ ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضِ وَمَا بَيْنَهُمَا ٱلرَّحْمَـٰنِ ۖ لَا يَمْلِكُونَ مِنْهُ خِطَابًا"},{"id":5710,"verse_key":"78:38","text_uthmani":"يَوْمَ يَقُومُ ٱلرُّوحُ وَٱلْمَلَـٰٓئِكَةُ صَفًّا ۖ لَّا يَتَكَلَّمُونَ إِلَّا مَنْ أَذِنَ لَهُ ٱلرَّحْمَـٰنُ وَقَالَ صَوَابًا"},{"id":5711,"verse_key":"78:39","text_uthmani":"ذَٰلِكَ ٱلْيَوْمُ ٱلْحَقُّ ۖ فَمَن شَآءَ ٱتَّخَذَ إِلَىٰ رَبِّهِۦ مَـَٔابًا"},{"id":5712,"verse_key":"78:40","text_uthmani":"إِنَّآ أَنذَرْنَـٰكُمْ عَذَابًا قَرِيبًا يَوْمَ يَنظُرُ ٱلْمَرْءُ مَا قَدَّمَتْ يَدَاهُ وَيَقُولُ ٱلْكَافِرُ يَـٰلَيْتَنِى كُنتُ تُرَٰبًۢا"},{"id":5713,"verse_key":"79:1","text_uthmani":" وَٱلنَّـٰزِعَـٰتِ غَرْقًا"},{"id":5714,"verse_key":"79:2","text_uthmani":"وَٱلنَّـٰشِطَـٰتِ نَشْطًا"},{"id":5715,"verse_key":"79:3","text_uthmani":"وَٱلسَّـٰبِحَـٰتِ سَبْحًا"},{"id":5716,"verse_key":"79:4","text_uthmani":"فَٱلسَّـٰبِقَـٰتِ سَبْقًا"},{"id":5717,"verse_key":"79:5","text_uthmani":"فَٱلْمُدَبِّرَٰتِ أَمْرًا"},{"id":5718,"verse_key":"79:6","text_uthmani":"يَوْمَ تَرْجُفُ ٱلرَّاجِفَةُ"},{"id":5719,"verse_key":"79:7","text_uthmani":"تَتْبَعُهَا ٱلرَّادِفَةُ"},{"id":5720,"verse_key":"79:8","text_uthmani":"قُلُوبٌ يَوْمَئِذٍ وَاجِفَةٌ"},{"id":5721,"verse_key":"79:9","text_uthmani":"أَبْصَـٰرُهَا خَـٰشِعَةٌ"},{"id":5722,"verse_key":"79:10","text_uthmani":"يَقُولُونَ أَءِنَّا لَمَرْدُودُونَ فِى ٱلْحَافِرَةِ"},{"id":5723,"verse_key":"79:11","text_uthmani":"أَءِذَا كُنَّا عِظَـٰمًا نَّخِرَةً"},{"id":5724,"verse_key":"79:12","text_uthmani":"قَالُوا۟ تِلْكَ إِذًا كَرَّةٌ خَاسِرَةٌ"},{"id":5725,"verse_key":"79:13","text_uthmani":"فَإِنَّمَا هِىَ زَجْرَةٌ وَٰحِدَةٌ"},{"id":5726,"verse_key":"79:14","text_uthmani":"فَإِذَا هُم بِٱلسَّاهِرَةِ"},{"id":5727,"verse_key":"79:15","text_uthmani":"هَلْ أَتَىٰكَ حَدِيثُ مُوسَىٰٓ"}]