[{"id":4454,"verse_key":"44:40","text_uthmani":"إِنَّ يَوْمَ ٱلْفَصْلِ مِيقَـٰتُهُمْ أَجْمَعِينَ"},{"id":4455,"verse_key":"44:41","text_uthmani":"يَوْمَ لَا يُغْنِى مَوْلًى عَن مَّوْلًى شَيْـًٔا وَلَا هُمْ يُنصَرُونَ"},{"id":4456,"verse_key":"44:42","text_uthmani":"إِلَّا مَن رَّحِمَ ٱللَّهُ ۚ إِنَّهُۥ هُوَ ٱلْعَزِيزُ ٱلرَّحِيمُ"},{"id":4457,"verse_key":"44:43","text_uthmani":"إِنَّ شَجَرَتَ ٱلزَّقُّومِ"},{"id":4458,"verse_key":"44:44","text_uthmani":"طَعَامُ ٱلْأَثِيمِ"},{"id":4459,"verse_key":"44:45","text_uthmani":"كَٱلْمُهْلِ يَغْلِى فِى ٱلْبُطُونِ"},{"id":4460,"verse_key":"44:46","text_uthmani":"كَغَلْىِ ٱلْحَمِيمِ"},{"id":4461,"verse_key":"44:47","text_uthmani":"خُذُوهُ فَٱعْتِلُوهُ إِلَىٰ سَوَآءِ ٱلْجَحِيمِ"},{"id":4462,"verse_key":"44:48","text_uthmani":"ثُمَّ صُبُّوا۟ فَوْقَ رَأْسِهِۦ مِنْ عَذَابِ ٱلْحَمِيمِ"},{"id":4463,"verse_key":"44:49","text_uthmani":"ذُقْ إِنَّكَ أَنتَ ٱلْعَزِيزُ ٱلْكَرِيمُ"},{"id":4464,"verse_key":"44:50","text_uthmani":"إِنَّ هَـٰذَا مَا كُنتُم بِهِۦ تَمْتَرُونَ"},{"id":4465,"verse_key":"44:51","text_uthmani":"إِنَّ ٱلْمُتَّقِينَ فِى مَقَامٍ أَمِينٍ"},{"id":4466,"verse_key":"44:52","text_uthmani":"فِى جَنَّـٰتٍ وَعُيُونٍ"},{"id":4467,"verse_key":"44:53","text_uthmani":"يَلْبَسُونَ مِن سُندُسٍ وَإِسْتَبْرَقٍ مُّتَقَـٰبِلِينَ"},{"id":4468,"verse_key":"44:54","text_uthmani":"كَذَٰلِكَ وَزَوَّجْنَـٰهُم بِحُورٍ عِينٍ"},{"id":4469,"verse_key":"44:55","text_uthmani":"يَدْعُونَ فِيهَا بِكُلِّ فَـٰكِهَةٍ ءَامِنِينَ"},{"id":4470,"verse_key":"44:56","text_uthmani":"لَا يَذُوقُونَ فِيهَا ٱلْمَوْتَ إِلَّا ٱلْمَوْتَةَ ٱلْأُولَىٰ ۖ وَوَقَىٰهُمْ عَذَابَ ٱلْجَحِيمِ"},{"id":4471,"verse_key":"44:57","text_uthmani":"فَضْلًا مِّن رَّبِّكَ ۚ ذَٰلِكَ هُوَ ٱلْفَوْزُ ٱلْعَظِيمُ"},{"id":4472,"verse_key":"44:58","text_uthmani":"فَإِنَّمَا يَسَّرْنَـٰهُ بِلِسَانِكَ لَعَلَّهُمْ يَتَذَكَّرُونَ"},{"id":4473,"verse_key":"44:59","text_uthmani":"فَٱرْتَقِبْ إِنَّهُم مُّرْتَقِبُونَ"}]