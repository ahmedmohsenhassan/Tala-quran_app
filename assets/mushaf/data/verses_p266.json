[{"id":1873,"verse_key":"15:71","text_uthmani":"قَالَ هَـٰٓؤُلَآءِ بَنَاتِىٓ إِن كُنتُمْ فَـٰعِلِينَ"},{"id":1874,"verse_key":"15:72","text_uthmani":"لَعَمْرُكَ إِنَّهُمْ لَفِى سَكْرَتِهِمْ يَعْمَهُونَ"},{"id":1875,"verse_key":"15:73","text_uthmani":"فَأَخَذَتْهُمُ ٱلصَّيْحَةُ مُشْرِقِينَ"},{"id":1876,"verse_key":"15:74","text_uthmani":"فَجَعَلْنَا عَـٰلِيَهَا سَافِلَهَا وَأَمْطَرْنَا عَلَيْهِمْ حِجَارَةً مِّن سِجِّيلٍ"},{"id":1877,"verse_key":"15:75","text_uthmani":"إِنَّ فِى ذَٰلِكَ لَـَٔايَـٰتٍ لِّلْمُتَوَسِّمِينَ"},{"id":1878,"verse_key":"15:76","text_uthmani":"وَإِنَّهَا لَبِسَبِيلٍ مُّقِيمٍ"},{"id":1879,"verse_key":"15:77","text_uthmani":"إِنَّ فِى ذَٰلِكَ لَـَٔايَةً لِّلْمُؤْمِنِينَ"},{"id":1880,"verse_key":"15:78","text_uthmani":"وَإِن كَانَ أَصْحَـٰبُ ٱلْأَيْكَةِ لَظَـٰلِمِينَ"},{"id":1881,"verse_key":"15:79","text_uthmani":"فَٱنتَقَمْنَا مِنْهُمْ وَإِنَّهُمَا لَبِإِمَامٍ مُّبِينٍ"},{"id":1882,"verse_key":"15:80","text_uthmani":"وَلَقَدْ كَذَّبَ أَصْحَـٰبُ ٱلْحِجْرِ ٱلْمُرْسَلِينَ"},{"id":1883,"verse_key":"15:81","text_uthmani":"وَءَاتَيْنَـٰهُمْ ءَايَـٰتِنَا فَكَانُوا۟ عَنْهَا مُعْرِضِينَ"},{"id":1884,"verse_key":"15:82","text_uthmani":"وَكَانُوا۟ يَنْحِتُونَ مِنَ ٱلْجِبَالِ بُيُوتًا ءَامِنِينَ"},{"id":1885,"verse_key":"15:83","text_uthmani":"فَأَخَذَتْهُمُ ٱلصَّيْحَةُ مُصْبِحِينَ"},{"id":1886,"verse_key":"15:84","text_uthmani":"فَمَآ أَغْنَىٰ عَنْهُم مَّا كَانُوا۟ يَكْسِبُونَ"},{"id":1887,"verse_key":"15:85","text_uthmani":"وَمَا خَلَقْنَا ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضَ وَمَا بَيْنَهُمَآ إِلَّا بِٱلْحَقِّ ۗ وَإِنَّ ٱلسَّاعَةَ لَـَٔاتِيَةٌ ۖ فَٱصْفَحِ ٱلصَّفْحَ ٱلْجَمِيلَ"},{"id":1888,"verse_key":"15:86","text_uthmani":"إِنَّ رَبَّكَ هُوَ ٱلْخَلَّـٰقُ ٱلْعَلِيمُ"},{"id":1889,"verse_key":"15:87","text_uthmani":"وَلَقَدْ ءَاتَيْنَـٰكَ سَبْعًا مِّنَ ٱلْمَثَانِى وَٱلْقُرْءَانَ ٱلْعَظِيمَ"},{"id":1890,"verse_key":"15:88","text_uthmani":"لَا تَمُدَّنَّ عَيْنَيْكَ إِلَىٰ مَا مَتَّعْنَا بِهِۦٓ أَزْوَٰجًا مِّنْهُمْ وَلَا تَحْزَنْ عَلَيْهِمْ وَٱخْفِضْ جَنَاحَكَ لِلْمُؤْمِنِينَ"},{"id":1891,"verse_key":"15:89","text_uthmani":"وَقُلْ إِنِّىٓ أَنَا ٱلنَّذِيرُ ٱلْمُبِينُ"},{"id":1892,"verse_key":"15:90","text_uthmani":"كَمَآ أَنزَلْنَا عَلَى ٱلْمُقْتَسِمِينَ"}]