[{"id":3891,"verse_key":"37:103","text_uthmani":"فَلَمَّآ أَسْلَمَا وَتَلَّهُۥ لِلْجَبِينِ"},{"id":3892,"verse_key":"37:104","text_uthmani":"وَنَـٰدَيْنَـٰهُ أَن يَـٰٓإِبْرَٰهِيمُ"},{"id":3893,"verse_key":"37:105","text_uthmani":"قَدْ صَدَّقْتَ ٱلرُّءْيَآ ۚ إِنَّا كَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ"},{"id":3894,"verse_key":"37:106","text_uthmani":"إِنَّ هَـٰذَا لَهُوَ ٱلْبَلَـٰٓؤُا۟ ٱلْمُبِينُ"},{"id":3895,"verse_key":"37:107","text_uthmani":"وَفَدَيْنَـٰهُ بِذِبْحٍ عَظِيمٍ"},{"id":3896,"verse_key":"37:108","text_uthmani":"وَتَرَكْنَا عَلَيْهِ فِى ٱلْـَٔاخِرِينَ"},{"id":3897,"verse_key":"37:109","text_uthmani":"سَلَـٰمٌ عَلَىٰٓ إِبْرَٰهِيمَ"},{"id":3898,"verse_key":"37:110","text_uthmani":"كَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ"},{"id":3899,"verse_key":"37:111","text_uthmani":"إِنَّهُۥ مِنْ عِبَادِنَا ٱلْمُؤْمِنِينَ"},{"id":3900,"verse_key":"37:112","text_uthmani":"وَبَشَّرْنَـٰهُ بِإِسْحَـٰقَ نَبِيًّا مِّنَ ٱلصَّـٰلِحِينَ"},{"id":3901,"verse_key":"37:113","text_uthmani":"وَبَـٰرَكْنَا عَلَيْهِ وَعَلَىٰٓ إِسْحَـٰقَ ۚ وَمِن ذُرِّيَّتِهِمَا مُحْسِنٌ وَظَالِمٌ لِّنَفْسِهِۦ مُبِينٌ"},{"id":3902,"verse_key":"37:114","text_uthmani":"وَلَقَدْ مَنَنَّا عَلَىٰ مُوسَىٰ وَهَـٰرُونَ"},{"id":3903,"verse_key":"37:115","text_uthmani":"وَنَجَّيْنَـٰهُمَا وَقَوْمَهُمَا مِنَ ٱلْكَرْبِ ٱلْعَظِيمِ"},{"id":3904,"verse_key":"37:116","text_uthmani":"وَنَصَرْنَـٰهُمْ فَكَانُوا۟ هُمُ ٱلْغَـٰلِبِينَ"},{"id":3905,"verse_key":"37:117","text_uthmani":"وَءَاتَيْنَـٰهُمَا ٱلْكِتَـٰبَ ٱلْمُسْتَبِينَ"},{"id":3906,"verse_key":"37:118","text_uthmani":"وَهَدَيْنَـٰهُمَا ٱلصِّرَٰطَ ٱلْمُسْتَقِيمَ"},{"id":3907,"verse_key":"37:119","text_uthmani":"وَتَرَكْنَا عَلَيْهِمَا فِى ٱلْـَٔاخِرِينَ"},{"id":3908,"verse_key":"37:120","text_uthmani":"سَلَـٰمٌ عَلَىٰ مُوسَىٰ وَهَـٰرُونَ"},{"id":3909,"verse_key":"37:121","text_uthmani":"إِنَّا كَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ"},{"id":3910,"verse_key":"37:122","text_uthmani":"إِنَّهُمَا مِنْ عِبَادِنَا ٱلْمُؤْمِنِينَ"},{"id":3911,"verse_key":"37:123","text_uthmani":"وَإِنَّ إِلْيَاسَ لَمِنَ ٱلْمُرْسَلِينَ"},{"id":3912,"verse_key":"37:124","text_uthmani":"إِذْ قَالَ لِقَوْمِهِۦٓ أَلَا تَتَّقُونَ"},{"id":3913,"verse_key":"37:125","text_uthmani":"أَتَدْعُونَ بَعْلًا وَتَذَرُونَ أَحْسَنَ ٱلْخَـٰلِقِينَ"},{"id":3914,"verse_key":"37:126","text_uthmani":"ٱللَّهَ رَبَّكُمْ وَرَبَّ ءَابَآئِكُمُ ٱلْأَوَّلِينَ"}]