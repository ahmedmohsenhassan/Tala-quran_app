[{"id":5030,"verse_key":"56:51","text_uthmani":"ثُمَّ إِنَّكُمْ أَيُّهَا ٱلضَّآلُّونَ ٱلْمُكَذِّبُونَ"},{"id":5031,"verse_key":"56:52","text_uthmani":"لَـَٔاكِلُونَ مِن شَجَرٍ مِّن زَقُّومٍ"},{"id":5032,"verse_key":"56:53","text_uthmani":"فَمَالِـُٔونَ مِنْهَا ٱلْبُطُونَ"},{"id":5033,"verse_key":"56:54","text_uthmani":"فَشَـٰرِبُونَ عَلَيْهِ مِنَ ٱلْحَمِيمِ"},{"id":5034,"verse_key":"56:55","text_uthmani":"فَشَـٰرِبُونَ شُرْبَ ٱلْهِيمِ"},{"id":5035,"verse_key":"56:56","text_uthmani":"هَـٰذَا نُزُلُهُمْ يَوْمَ ٱلدِّينِ"},{"id":5036,"verse_key":"56:57","text_uthmani":"نَحْنُ خَلَقْنَـٰكُمْ فَلَوْلَا تُصَدِّقُونَ"},{"id":5037,"verse_key":"56:58","text_uthmani":"أَفَرَءَيْتُم مَّا تُمْنُونَ"},{"id":5038,"verse_key":"56:59","text_uthmani":"ءَأَنتُمْ تَخْلُقُونَهُۥٓ أَمْ نَحْنُ ٱلْخَـٰلِقُونَ"},{"id":5039,"verse_key":"56:60","text_uthmani":"نَحْنُ قَدَّرْنَا بَيْنَكُمُ ٱلْمَوْتَ وَمَا نَحْنُ بِمَسْبُوقِينَ"},{"id":5040,"verse_key":"56:61","text_uthmani":"عَلَىٰٓ أَن نُّبَدِّلَ أَمْثَـٰلَكُمْ وَنُنشِئَكُمْ فِى مَا لَا تَعْلَمُونَ"},{"id":5041,"verse_key":"56:62","text_uthmani":"وَلَقَدْ عَلِمْتُمُ ٱلنَّشْأَةَ ٱلْأُولَىٰ فَلَوْلَا تَذَكَّرُونَ"},{"id":5042,"verse_key":"56:63","text_uthmani":"أَفَرَءَيْتُم مَّا تَحْرُثُونَ"},{"id":5043,"verse_key":"56:64","text_uthmani":"ءَأَنتُمْ تَزْرَعُونَهُۥٓ أَمْ نَحْنُ ٱلزَّٰرِعُونَ"},{"id":5044,"verse_key":"56:65","text_uthmani":"لَوْ نَشَآءُ لَجَعَلْنَـٰهُ حُطَـٰمًا فَظَلْتُمْ تَفَكَّهُونَ"},{"id":5045,"verse_key":"56:66","text_uthmani":"إِنَّا لَمُغْرَمُونَ"},{"id":5046,"verse_key":"56:67","text_uthmani":"بَلْ نَحْنُ مَحْرُومُونَ"},{"id":5047,"verse_key":"56:68","text_uthmani":"أَفَرَءَيْتُمُ ٱلْمَآءَ ٱلَّذِى تَشْرَبُونَ"},{"id":5048,"verse_key":"56:69","text_uthmani":"ءَأَنتُمْ أَنزَلْتُمُوهُ مِنَ ٱلْمُزْنِ أَمْ نَحْنُ ٱلْمُنزِلُونَ"},{"id":5049,"verse_key":"56:70","text_uthmani":"لَوْ نَشَآءُ جَعَلْنَـٰهُ أُجَاجًا فَلَوْلَا تَشْكُرُونَ"},{"id":5050,"verse_key":"56:71","text_uthmani":"أَفَرَءَيْتُمُ ٱلنَّارَ ٱلَّتِى تُورُونَ"},{"id":5051,"verse_key":"56:72","text_uthmani":"ءَأَنتُمْ أَنشَأْتُمْ شَجَرَتَهَآ أَمْ نَحْنُ ٱلْمُنشِـُٔونَ"},{"id":5052,"verse_key":"56:73","text_uthmani":"نَحْنُ جَعَلْنَـٰهَا تَذْكِرَةً وَمَتَـٰعًا لِّلْمُقْوِينَ"},{"id":5053,"verse_key":"56:74","text_uthmani":"فَسَبِّحْ بِٱسْمِ رَبِّكَ ٱلْعَظِيمِ"},{"id":5054,"verse_key":"56:75","text_uthmani":"۞ فَلَآ أُقْسِمُ بِمَوَٰقِعِ ٱلنُّجُومِ"},{"id":5055,"verse_key":"56:76","text_uthmani":"وَإِنَّهُۥ لَقَسَمٌ لَّوْ تَعْلَمُونَ عَظِيمٌ"}]