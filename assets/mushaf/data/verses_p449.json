[{"id":3865,"verse_key":"37:77","text_uthmani":"وَجَعَلْنَا ذُرِّيَّتَهُۥ هُمُ ٱلْبَاقِينَ"},{"id":3866,"verse_key":"37:78","text_uthmani":"وَتَرَكْنَا عَلَيْهِ فِى ٱلْـَٔاخِرِينَ"},{"id":3867,"verse_key":"37:79","text_uthmani":"سَلَـٰمٌ عَلَىٰ نُوحٍ فِى ٱلْعَـٰلَمِينَ"},{"id":3868,"verse_key":"37:80","text_uthmani":"إِنَّا كَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ"},{"id":3869,"verse_key":"37:81","text_uthmani":"إِنَّهُۥ مِنْ عِبَادِنَا ٱلْمُؤْمِنِينَ"},{"id":3870,"verse_key":"37:82","text_uthmani":"ثُمَّ أَغْرَقْنَا ٱلْـَٔاخَرِينَ"},{"id":3871,"verse_key":"37:83","text_uthmani":"۞ وَإِنَّ مِن شِيعَتِهِۦ لَإِبْرَٰهِيمَ"},{"id":3872,"verse_key":"37:84","text_uthmani":"إِذْ جَآءَ رَبَّهُۥ بِقَلْبٍ سَلِيمٍ"},{"id":3873,"verse_key":"37:85","text_uthmani":"إِذْ قَالَ لِأَبِيهِ وَقَوْمِهِۦ مَاذَا تَعْبُدُونَ"},{"id":3874,"verse_key":"37:86","text_uthmani":"أَئِفْكًا ءَالِهَةً دُونَ ٱللَّهِ تُرِيدُونَ"},{"id":3875,"verse_key":"37:87","text_uthmani":"فَمَا ظَنُّكُم بِرَبِّ ٱلْعَـٰلَمِينَ"},{"id":3876,"verse_key":"37:88","text_uthmani":"فَنَظَرَ نَظْرَةً فِى ٱلنُّجُومِ"},{"id":3877,"verse_key":"37:89","text_uthmani":"فَقَالَ إِنِّى سَقِيمٌ"},{"id":3878,"verse_key":"37:90","text_uthmani":"فَتَوَلَّوْا۟ عَنْهُ مُدْبِرِينَ"},{"id":3879,"verse_key":"37:91","text_uthmani":"فَرَاغَ إِلَىٰٓ ءَالِهَتِهِمْ فَقَالَ أَلَا تَأْكُلُونَ"},{"id":3880,"verse_key":"37:92","text_uthmani":"مَا لَكُمْ لَا تَنطِقُونَ"},{"id":3881,"verse_key":"37:93","text_uthmani":"فَرَاغَ عَلَيْهِمْ ضَرْبًۢا بِٱلْيَمِينِ"},{"id":3882,"verse_key":"37:94","text_uthmani":"فَأَقْبَلُوٓا۟ إِلَيْهِ يَزِفُّونَ"},{"id":3883,"verse_key":"37:95","text_uthmani":"قَالَ أَتَعْبُدُونَ مَا تَنْحِتُونَ"},{"id":3884,"verse_key":"37:96","text_uthmani":"وَٱللَّهُ خَلَقَكُمْ وَمَا تَعْمَلُونَ"},{"id":3885,"verse_key":"37:97","text_uthmani":"قَالُوا۟ ٱبْنُوا۟ لَهُۥ بُنْيَـٰنًا فَأَلْقُوهُ فِى ٱلْجَحِيمِ"},{"id":3886,"verse_key":"37:98","text_uthmani":"فَأَرَادُوا۟ بِهِۦ كَيْدًا فَجَعَلْنَـٰهُمُ ٱلْأَسْفَلِينَ"},{"id":3887,"verse_key":"37:99","text_uthmani":"وَقَالَ إِنِّى ذَاهِبٌ إِلَىٰ رَبِّى سَيَهْدِينِ"},{"id":3888,"verse_key":"37:100","text_uthmani":"رَبِّ هَبْ لِى مِنَ ٱلصَّـٰلِحِينَ"},{"id":3889,"verse_key":"37:101","text_uthmani":"فَبَشَّرْنَـٰهُ بِغُلَـٰمٍ حَلِيمٍ"},{"id":3890,"verse_key":"37:102","text_uthmani":"فَلَمَّا بَلَغَ مَعَهُ ٱلسَّعْىَ قَالَ يَـٰبُنَىَّ إِنِّىٓ أَرَىٰ فِى ٱلْمَنَامِ أَنِّىٓ أَذْبَحُكَ فَٱنظُرْ مَاذَا تَرَىٰ ۚ قَالَ يَـٰٓأَبَتِ ٱفْعَلْ مَا تُؤْمَرُ ۖ سَتَجِدُنِىٓ إِن شَآءَ ٱللَّهُ مِنَ ٱلصَّـٰبِرِينَ"}]