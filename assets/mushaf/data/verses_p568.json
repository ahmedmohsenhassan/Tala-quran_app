[{"id":5358,"verse_key":"69:35","text_uthmani":"فَلَيْسَ لَهُ ٱلْيَوْمَ هَـٰهُنَا حَمِيمٌ"},{"id":5359,"verse_key":"69:36","text_uthmani":"وَلَا طَعَامٌ إِلَّا مِنْ غِسْلِينٍ"},{"id":5360,"verse_key":"69:37","text_uthmani":"لَّا يَأْكُلُهُۥٓ إِلَّا ٱلْخَـٰطِـُٔونَ"},{"id":5361,"verse_key":"69:38","text_uthmani":"فَلَآ أُقْسِمُ بِمَا تُبْصِرُونَ"},{"id":5362,"verse_key":"69:39","text_uthmani":"وَمَا لَا تُبْصِرُونَ"},{"id":5363,"verse_key":"69:40","text_uthmani":"إِنَّهُۥ لَقَوْلُ رَسُولٍ كَرِيمٍ"},{"id":5364,"verse_key":"69:41","text_uthmani":"وَمَا هُوَ بِقَوْلِ شَاعِرٍ ۚ قَلِيلًا مَّا تُؤْمِنُونَ"},{"id":5365,"verse_key":"69:42","text_uthmani":"وَلَا بِقَوْلِ كَاهِنٍ ۚ قَلِيلًا مَّا تَذَكَّرُونَ"},{"id":5366,"verse_key":"69:43","text_uthmani":"تَنزِيلٌ مِّن رَّبِّ ٱلْعَـٰلَمِينَ"},{"id":5367,"verse_key":"69:44","text_uthmani":"وَلَوْ تَقَوَّلَ عَلَيْنَا بَعْضَ ٱلْأَقَاوِيلِ"},{"id":5368,"verse_key":"69:45","text_uthmani":"لَأَخَذْنَا مِنْهُ بِٱلْيَمِينِ"},{"id":5369,"verse_key":"69:46","text_uthmani":"ثُمَّ لَقَطَعْنَا مِنْهُ ٱلْوَتِينَ"},{"id":5370,"verse_key":"69:47","text_uthmani":"فَمَا مِنكُم مِّنْ أَحَدٍ عَنْهُ حَـٰجِزِينَ"},{"id":5371,"verse_key":"69:48","text_uthmani":"وَإِنَّهُۥ لَتَذْكِرَةٌ لِّلْمُتَّقِينَ"},{"id":5372,"verse_key":"69:49","text_uthmani":"وَإِنَّا لَنَعْلَمُ أَنَّ مِنكُم مُّكَذِّبِينَ"},{"id":5373,"verse_key":"69:50","text_uthmani":"وَإِنَّهُۥ لَحَسْرَةٌ عَلَى ٱلْكَـٰفِرِينَ"},{"id":5374,"verse_key":"69:51","text_uthmani":"وَإِنَّهُۥ لَحَقُّ ٱلْيَقِينِ"},{"id":5375,"verse_key":"69:52","text_uthmani":"فَسَبِّحْ بِٱسْمِ رَبِّكَ ٱلْعَظِيمِ"},{"id":5376,"verse_key":"70:1","text_uthmani":" سَأَلَ سَآئِلٌۢ بِعَذَابٍ وَاقِعٍ"},{"id":5377,"verse_key":"70:2","text_uthmani":"لِّلْكَـٰفِرِينَ لَيْسَ لَهُۥ دَافِعٌ"},{"id":5378,"verse_key":"70:3","text_uthmani":"مِّنَ ٱللَّهِ ذِى ٱلْمَعَارِجِ"},{"id":5379,"verse_key":"70:4","text_uthmani":"تَعْرُجُ ٱلْمَلَـٰٓئِكَةُ وَٱلرُّوحُ إِلَيْهِ فِى يَوْمٍ كَانَ مِقْدَارُهُۥ خَمْسِينَ أَلْفَ سَنَةٍ"},{"id":5380,"verse_key":"70:5","text_uthmani":"فَٱصْبِرْ صَبْرًا جَمِيلًا"},{"id":5381,"verse_key":"70:6","text_uthmani":"إِنَّهُمْ يَرَوْنَهُۥ بَعِيدًا"},{"id":5382,"verse_key":"70:7","text_uthmani":"وَنَرَىٰهُ قَرِيبًا"},{"id":5383,"verse_key":"70:8","text_uthmani":"يَوْمَ تَكُونُ ٱلسَّمَآءُ كَٱلْمُهْلِ"},{"id":5384,"verse_key":"70:9","text_uthmani":"وَتَكُونُ ٱلْجِبَالُ كَٱلْعِهْنِ"},{"id":5385,"verse_key":"70:10","text_uthmani":"وَلَا يَسْـَٔلُ حَمِيمٌ حَمِيمًا"}]