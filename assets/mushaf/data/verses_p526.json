[{"id":4785,"verse_key":"53:1","text_uthmani":" وَٱلنَّجْمِ إِذَا هَوَىٰ"},{"id":4786,"verse_key":"53:2","text_uthmani":"مَا ضَلَّ صَاحِبُكُمْ وَمَا غَوَىٰ"},{"id":4787,"verse_key":"53:3","text_uthmani":"وَمَا يَنطِقُ عَنِ ٱلْهَوَىٰٓ"},{"id":4788,"verse_key":"53:4","text_uthmani":"إِنْ هُوَ إِلَّا وَحْىٌ يُوحَىٰ"},{"id":4789,"verse_key":"53:5","text_uthmani":"عَلَّمَهُۥ شَدِيدُ ٱلْقُوَىٰ"},{"id":4790,"verse_key":"53:6","text_uthmani":"ذُو مِرَّةٍ فَٱسْتَوَىٰ"},{"id":4791,"verse_key":"53:7","text_uthmani":"وَهُوَ بِٱلْأُفُقِ ٱلْأَعْلَىٰ"},{"id":4792,"verse_key":"53:8","text_uthmani":"ثُمَّ دَنَا فَتَدَلَّىٰ"},{"id":4793,"verse_key":"53:9","text_uthmani":"فَكَانَ قَابَ قَوْسَيْنِ أَوْ أَدْنَىٰ"},{"id":4794,"verse_key":"53:10","text_uthmani":"فَأَوْحَىٰٓ إِلَىٰ عَبْدِهِۦ مَآ أَوْحَىٰ"},{"id":4795,"verse_key":"53:11","text_uthmani":"مَا كَذَبَ ٱلْفُؤَادُ مَا رَأَىٰٓ"},{"id":4796,"verse_key":"53:12","text_uthmani":"أَفَتُمَـٰرُونَهُۥ عَلَىٰ مَا يَرَىٰ"},{"id":4797,"verse_key":"53:13","text_uthmani":"وَلَقَدْ رَءَاهُ نَزْلَةً أُخْرَىٰ"},{"id":4798,"verse_key":"53:14","text_uthmani":"عِندَ سِدْرَةِ ٱلْمُنتَهَىٰ"},{"id":4799,"verse_key":"53:15","text_uthmani":"عِندَهَا جَنَّةُ ٱلْمَأْوَىٰٓ"},{"id":4800,"verse_key":"53:16","text_uthmani":"إِذْ يَغْشَى ٱلسِّدْرَةَ مَا يَغْشَىٰ"},{"id":4801,"verse_key":"53:17","text_uthmani":"مَا زَاغَ ٱلْبَصَرُ وَمَا طَغَىٰ"},{"id":4802,"verse_key":"53:18","text_uthmani":"لَقَدْ رَأَىٰ مِنْ ءَايَـٰتِ رَبِّهِ ٱلْكُبْرَىٰٓ"},{"id":4803,"verse_key":"53:19","text_uthmani":"أَفَرَءَيْتُمُ ٱللَّـٰتَ وَٱلْعُزَّىٰ"},{"id":4804,"verse_key":"53:20","text_uthmani":"وَمَنَوٰةَ ٱلثَّالِثَةَ ٱلْأُخْرَىٰٓ"},{"id":4805,"verse_key":"53:21","text_uthmani":"أَلَكُمُ ٱلذَّكَرُ وَلَهُ ٱلْأُنثَىٰ"},{"id":4806,"verse_key":"53:22","text_uthmani":"تِلْكَ إِذًا قِسْمَةٌ ضِيزَىٰٓ"},{"id":4807,"verse_key":"53:23","text_uthmani":"إِنْ هِىَ إِلَّآ أَسْمَآءٌ سَمَّيْتُمُوهَآ أَنتُمْ وَءَابَآؤُكُم مَّآ أَنزَلَ ٱللَّهُ بِهَا مِن سُلْطَـٰنٍ ۚ إِن يَتَّبِعُونَ إِلَّا ٱلظَّنَّ وَمَا تَهْوَى ٱلْأَنفُسُ ۖ وَلَقَدْ جَآءَهُم مِّن رَّبِّهِمُ ٱلْهُدَىٰٓ"},{"id":4808,"verse_key":"53:24","text_uthmani":"أَمْ لِلْإِنسَـٰنِ مَا تَمَنَّىٰ"},{"id":4809,"verse_key":"53:25","text_uthmani":"فَلِلَّهِ ٱلْـَٔاخِرَةُ وَٱلْأُولَىٰ"},{"id":4810,"verse_key":"53:26","text_uthmani":"۞ وَكَم مِّن مَّلَكٍ فِى ٱلسَّمَـٰوَٰتِ لَا تُغْنِى شَفَـٰعَتُهُمْ شَيْـًٔا إِلَّا مِنۢ بَعْدِ أَن يَأْذَنَ ٱللَّهُ لِمَن يَشَآءُ وَيَرْضَىٰٓ"}]