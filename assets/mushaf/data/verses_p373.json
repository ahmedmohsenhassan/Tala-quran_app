[{"id":3069,"verse_key":"26:137","text_uthmani":"إِنْ هَـٰذَآ إِلَّا خُلُقُ ٱلْأَوَّلِينَ"},{"id":3070,"verse_key":"26:138","text_uthmani":"وَمَا نَحْنُ بِمُعَذَّبِينَ"},{"id":3071,"verse_key":"26:139","text_uthmani":"فَكَذَّبُوهُ فَأَهْلَكْنَـٰهُمْ ۗ إِنَّ فِى ذَٰلِكَ لَـَٔايَةً ۖ وَمَا كَانَ أَكْثَرُهُم مُّؤْمِنِينَ"},{"id":3072,"verse_key":"26:140","text_uthmani":"وَإِنَّ رَبَّكَ لَهُوَ ٱلْعَزِيزُ ٱلرَّحِيمُ"},{"id":3073,"verse_key":"26:141","text_uthmani":"كَذَّبَتْ ثَمُودُ ٱلْمُرْسَلِينَ"},{"id":3074,"verse_key":"26:142","text_uthmani":"إِذْ قَالَ لَهُمْ أَخُوهُمْ صَـٰلِحٌ أَلَا تَتَّقُونَ"},{"id":3075,"verse_key":"26:143","text_uthmani":"إِنِّى لَكُمْ رَسُولٌ أَمِينٌ"},{"id":3076,"verse_key":"26:144","text_uthmani":"فَٱتَّقُوا۟ ٱللَّهَ وَأَطِيعُونِ"},{"id":3077,"verse_key":"26:145","text_uthmani":"وَمَآ أَسْـَٔلُكُمْ عَلَيْهِ مِنْ أَجْرٍ ۖ إِنْ أَجْرِىَ إِلَّا عَلَىٰ رَبِّ ٱلْعَـٰلَمِينَ"},{"id":3078,"verse_key":"26:146","text_uthmani":"أَتُتْرَكُونَ فِى مَا هَـٰهُنَآ ءَامِنِينَ"},{"id":3079,"verse_key":"26:147","text_uthmani":"فِى جَنَّـٰتٍ وَعُيُونٍ"},{"id":3080,"verse_key":"26:148","text_uthmani":"وَزُرُوعٍ وَنَخْلٍ طَلْعُهَا هَضِيمٌ"},{"id":3081,"verse_key":"26:149","text_uthmani":"وَتَنْحِتُونَ مِنَ ٱلْجِبَالِ بُيُوتًا فَـٰرِهِينَ"},{"id":3082,"verse_key":"26:150","text_uthmani":"فَٱتَّقُوا۟ ٱللَّهَ وَأَطِيعُونِ"},{"id":3083,"verse_key":"26:151","text_uthmani":"وَلَا تُطِيعُوٓا۟ أَمْرَ ٱلْمُسْرِفِينَ"},{"id":3084,"verse_key":"26:152","text_uthmani":"ٱلَّذِينَ يُفْسِدُونَ فِى ٱلْأَرْضِ وَلَا يُصْلِحُونَ"},{"id":3085,"verse_key":"26:153","text_uthmani":"قَالُوٓا۟ إِنَّمَآ أَنتَ مِنَ ٱلْمُسَحَّرِينَ"},{"id":3086,"verse_key":"26:154","text_uthmani":"مَآ أَنتَ إِلَّا بَشَرٌ مِّثْلُنَا فَأْتِ بِـَٔايَةٍ إِن كُنتَ مِنَ ٱلصَّـٰدِقِينَ"},{"id":3087,"verse_key":"26:155","text_uthmani":"قَالَ هَـٰذِهِۦ نَاقَةٌ لَّهَا شِرْبٌ وَلَكُمْ شِرْبُ يَوْمٍ مَّعْلُومٍ"},{"id":3088,"verse_key":"26:156","text_uthmani":"وَلَا تَمَسُّوهَا بِسُوٓءٍ فَيَأْخُذَكُمْ عَذَابُ يَوْمٍ عَظِيمٍ"},{"id":3089,"verse_key":"26:157","text_uthmani":"فَعَقَرُوهَا فَأَصْبَحُوا۟ نَـٰدِمِينَ"},{"id":3090,"verse_key":"26:158","text_uthmani":"فَأَخَذَهُمُ ٱلْعَذَابُ ۗ إِنَّ فِى ذَٰلِكَ لَـَٔايَةً ۖ وَمَا كَانَ أَكْثَرُهُم مُّؤْمِنِينَ"},{"id":3091,"verse_key":"26:159","text_uthmani":"وَإِنَّ رَبَّكَ لَهُوَ ٱلْعَزِيزُ ٱلرَّحِيمُ"}]