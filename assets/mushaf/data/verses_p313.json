[{"id":2361,"verse_key":"20:13","text_uthmani":"وَأَنَا ٱخْتَرْتُكَ فَٱسْتَمِعْ لِمَا يُوحَىٰٓ"},{"id":2362,"verse_key":"20:14","text_uthmani":"إِنَّنِىٓ أَنَا ٱللَّهُ لَآ إِلَـٰهَ إِلَّآ أَنَا۠ فَٱعْبُدْنِى وَأَقِمِ ٱلصَّلَوٰةَ لِذِكْرِىٓ"},{"id":2363,"verse_key":"20:15","text_uthmani":"إِنَّ ٱلسَّاعَةَ ءَاتِيَةٌ أَكَادُ أُخْفِيهَا لِتُجْزَىٰ كُلُّ نَفْسٍۭ بِمَا تَسْعَىٰ"},{"id":2364,"verse_key":"20:16","text_uthmani":"فَلَا يَصُدَّنَّكَ عَنْهَا مَن لَّا يُؤْمِنُ بِهَا وَٱتَّبَعَ هَوَىٰهُ فَتَرْدَىٰ"},{"id":2365,"verse_key":"20:17","text_uthmani":"وَمَا تِلْكَ بِيَمِينِكَ يَـٰمُوسَىٰ"},{"id":2366,"verse_key":"20:18","text_uthmani":"قَالَ هِىَ عَصَاىَ أَتَوَكَّؤُا۟ عَلَيْهَا وَأَهُشُّ بِهَا عَلَىٰ غَنَمِى وَلِىَ فِيهَا مَـَٔارِبُ أُخْرَىٰ"},{"id":2367,"verse_key":"20:19","text_uthmani":"قَالَ أَلْقِهَا يَـٰمُوسَىٰ"},{"id":2368,"verse_key":"20:20","text_uthmani":"فَأَلْقَىٰهَا فَإِذَا هِىَ حَيَّةٌ تَسْعَىٰ"},{"id":2369,"verse_key":"20:21","text_uthmani":"قَالَ خُذْهَا وَلَا تَخَفْ ۖ سَنُعِيدُهَا سِيرَتَهَا ٱلْأُولَىٰ"},{"id":2370,"verse_key":"20:22","text_uthmani":"وَٱضْمُمْ يَدَكَ إِلَىٰ جَنَاحِكَ تَخْرُجْ بَيْضَآءَ مِنْ غَيْرِ سُوٓءٍ ءَايَةً أُخْرَىٰ"},{"id":2371,"verse_key":"20:23","text_uthmani":"لِنُرِيَكَ مِنْ ءَايَـٰتِنَا ٱلْكُبْرَى"},{"id":2372,"verse_key":"20:24","text_uthmani":"ٱذْهَبْ إِلَىٰ فِرْعَوْنَ إِنَّهُۥ طَغَىٰ"},{"id":2373,"verse_key":"20:25","text_uthmani":"قَالَ رَبِّ ٱشْرَحْ لِى صَدْرِى"},{"id":2374,"verse_key":"20:26","text_uthmani":"وَيَسِّرْ لِىٓ أَمْرِى"},{"id":2375,"verse_key":"20:27","text_uthmani":"وَٱحْلُلْ عُقْدَةً مِّن لِّسَانِى"},{"id":2376,"verse_key":"20:28","text_uthmani":"يَفْقَهُوا۟ قَوْلِى"},{"id":2377,"verse_key":"20:29","text_uthmani":"وَٱجْعَل لِّى وَزِيرًا مِّنْ أَهْلِى"},{"id":2378,"verse_key":"20:30","text_uthmani":"هَـٰرُونَ أَخِى"},{"id":2379,"verse_key":"20:31","text_uthmani":"ٱشْدُدْ بِهِۦٓ أَزْرِى"},{"id":2380,"verse_key":"20:32","text_uthmani":"وَأَشْرِكْهُ فِىٓ أَمْرِى"},{"id":2381,"verse_key":"20:33","text_uthmani":"كَىْ نُسَبِّحَكَ كَثِيرًا"},{"id":2382,"verse_key":"20:34","text_uthmani":"وَنَذْكُرَكَ كَثِيرًا"},{"id":2383,"verse_key":"20:35","text_uthmani":"إِنَّكَ كُنتَ بِنَا بَصِيرًا"},{"id":2384,"verse_key":"20:36","text_uthmani":"قَالَ قَدْ أُوتِيتَ سُؤْلَكَ يَـٰمُوسَىٰ"},{"id":2385,"verse_key":"20:37","text_uthmani":"وَلَقَدْ مَنَنَّا عَلَيْكَ مَرَّةً أُخْرَىٰٓ"}]