[{"id":3840,"verse_key":"37:52","text_uthmani":"يَقُولُ أَءِنَّكَ لَمِنَ ٱلْمُصَدِّقِينَ"},{"id":3841,"verse_key":"37:53","text_uthmani":"أَءِذَا مِتْنَا وَكُنَّا تُرَابًا وَعِظَـٰمًا أَءِنَّا لَمَدِينُونَ"},{"id":3842,"verse_key":"37:54","text_uthmani":"قَالَ هَلْ أَنتُم مُّطَّلِعُونَ"},{"id":3843,"verse_key":"37:55","text_uthmani":"فَٱطَّلَعَ فَرَءَاهُ فِى سَوَآءِ ٱلْجَحِيمِ"},{"id":3844,"verse_key":"37:56","text_uthmani":"قَالَ تَٱللَّهِ إِن كِدتَّ لَتُرْدِينِ"},{"id":3845,"verse_key":"37:57","text_uthmani":"وَلَوْلَا نِعْمَةُ رَبِّى لَكُنتُ مِنَ ٱلْمُحْضَرِينَ"},{"id":3846,"verse_key":"37:58","text_uthmani":"أَفَمَا نَحْنُ بِمَيِّتِينَ"},{"id":3847,"verse_key":"37:59","text_uthmani":"إِلَّا مَوْتَتَنَا ٱلْأُولَىٰ وَمَا نَحْنُ بِمُعَذَّبِينَ"},{"id":3848,"verse_key":"37:60","text_uthmani":"إِنَّ هَـٰذَا لَهُوَ ٱلْفَوْزُ ٱلْعَظِيمُ"},{"id":3849,"verse_key":"37:61","text_uthmani":"لِمِثْلِ هَـٰذَا فَلْيَعْمَلِ ٱلْعَـٰمِلُونَ"},{"id":3850,"verse_key":"37:62","text_uthmani":"أَذَٰلِكَ خَيْرٌ نُّزُلًا أَمْ شَجَرَةُ ٱلزَّقُّومِ"},{"id":3851,"verse_key":"37:63","text_uthmani":"إِنَّا جَعَلْنَـٰهَا فِتْنَةً لِّلظَّـٰلِمِينَ"},{"id":3852,"verse_key":"37:64","text_uthmani":"إِنَّهَا شَجَرَةٌ تَخْرُجُ فِىٓ أَصْلِ ٱلْجَحِيمِ"},{"id":3853,"verse_key":"37:65","text_uthmani":"طَلْعُهَا كَأَنَّهُۥ رُءُوسُ ٱلشَّيَـٰطِينِ"},{"id":3854,"verse_key":"37:66","text_uthmani":"فَإِنَّهُمْ لَـَٔاكِلُونَ مِنْهَا فَمَالِـُٔونَ مِنْهَا ٱلْبُطُونَ"},{"id":3855,"verse_key":"37:67","text_uthmani":"ثُمَّ إِنَّ لَهُمْ عَلَيْهَا لَشَوْبًا مِّنْ حَمِيمٍ"},{"id":3856,"verse_key":"37:68","text_uthmani":"ثُمَّ إِنَّ مَرْجِعَهُمْ لَإِلَى ٱلْجَحِيمِ"},{"id":3857,"verse_key":"37:69","text_uthmani":"إِنَّهُمْ أَلْفَوْا۟ ءَابَآءَهُمْ ضَآلِّينَ"},{"id":3858,"verse_key":"37:70","text_uthmani":"فَهُمْ عَلَىٰٓ ءَاثَـٰرِهِمْ يُهْرَعُونَ"},{"id":3859,"verse_key":"37:71","text_uthmani":"وَلَقَدْ ضَلَّ قَبْلَهُمْ أَكْثَرُ ٱلْأَوَّلِينَ"},{"id":3860,"verse_key":"37:72","text_uthmani":"وَلَقَدْ أَرْسَلْنَا فِيهِم مُّنذِرِينَ"},{"id":3861,"verse_key":"37:73","text_uthmani":"فَٱنظُرْ كَيْفَ كَانَ عَـٰقِبَةُ ٱلْمُنذَرِينَ"},{"id":3862,"verse_key":"37:74","text_uthmani":"إِلَّا عِبَادَ ٱللَّهِ ٱلْمُخْلَصِينَ"},{"id":3863,"verse_key":"37:75","text_uthmani":"وَلَقَدْ نَادَىٰنَا نُوحٌ فَلَنِعْمَ ٱلْمُجِيبُونَ"},{"id":3864,"verse_key":"37:76","text_uthmani":"وَنَجَّيْنَـٰهُ وَأَهْلَهُۥ مِنَ ٱلْكَرْبِ ٱلْعَظِيمِ"}]