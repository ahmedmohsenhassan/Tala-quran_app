[{"id":6044,"verse_key":"91:1","text_uthmani":" وَٱلشَّمْسِ وَضُحَىٰهَا"},{"id":6045,"verse_key":"91:2","text_uthmani":"وَٱلْقَمَرِ إِذَا تَلَىٰهَا"},{"id":6046,"verse_key":"91:3","text_uthmani":"وَٱلنَّهَارِ إِذَا جَلَّىٰهَا"},{"id":6047,"verse_key":"91:4","text_uthmani":"وَٱلَّيْلِ إِذَا يَغْشَىٰهَا"},{"id":6048,"verse_key":"91:5","text_uthmani":"وَٱلسَّمَآءِ وَمَا بَنَىٰهَا"},{"id":6049,"verse_key":"91:6","text_uthmani":"وَٱلْأَرْضِ وَمَا طَحَىٰهَا"},{"id":6050,"verse_key":"91:7","text_uthmani":"وَنَفْسٍ وَمَا سَوَّىٰهَا"},{"id":6051,"verse_key":"91:8","text_uthmani":"فَأَلْهَمَهَا فُجُورَهَا وَتَقْوَىٰهَا"},{"id":6052,"verse_key":"91:9","text_uthmani":"قَدْ أَفْلَحَ مَن زَكَّىٰهَا"},{"id":6053,"verse_key":"91:10","text_uthmani":"وَقَدْ خَابَ مَن دَسَّىٰهَا"},{"id":6054,"verse_key":"91:11","text_uthmani":"كَذَّبَتْ ثَمُودُ بِطَغْوَىٰهَآ"},{"id":6055,"verse_key":"91:12","text_uthmani":"إِذِ ٱنۢبَعَثَ أَشْقَىٰهَا"},{"id":6056,"verse_key":"91:13","text_uthmani":"فَقَالَ لَهُمْ رَسُولُ ٱللَّهِ نَاقَةَ ٱللَّهِ وَسُقْيَـٰهَا"},{"id":6057,"verse_key":"91:14","text_uthmani":"فَكَذَّبُوهُ فَعَقَرُوهَا فَدَمْدَمَ عَلَيْهِمْ رَبُّهُم بِذَنۢبِهِمْ فَسَوَّىٰهَا"},{"id":6058,"verse_key":"91:15","text_uthmani":"وَلَا يَخَافُ عُقْبَـٰهَا"},{"id":6059,"verse_key":"92:1","text_uthmani":" وَٱلَّيْلِ إِذَا يَغْشَىٰ"},{"id":6060,"verse_key":"92:2","text_uthmani":"وَٱلنَّهَارِ إِذَا تَجَلَّىٰ"},{"id":6061,"verse_key":"92:3","text_uthmani":"وَمَا خَلَقَ ٱلذَّكَرَ وَٱلْأُنثَىٰٓ"},{"id":6062,"verse_key":"92:4","text_uthmani":"إِنَّ سَعْيَكُمْ لَشَتَّىٰ"},{"id":6063,"verse_key":"92:5","text_uthmani":"فَأَمَّا مَنْ أَعْطَىٰ وَٱتَّقَىٰ"},{"id":6064,"verse_key":"92:6","text_uthmani":"وَصَدَّقَ بِٱلْحُسْنَىٰ"},{"id":6065,"verse_key":"92:7","text_uthmani":"فَسَنُيَسِّرُهُۥ لِلْيُسْرَىٰ"},{"id":6066,"verse_key":"92:8","text_uthmani":"وَأَمَّا مَنۢ بَخِلَ وَٱسْتَغْنَىٰ"},{"id":6067,"verse_key":"92:9","text_uthmani":"وَكَذَّبَ بِٱلْحُسْنَىٰ"},{"id":6068,"verse_key":"92:10","text_uthmani":"فَسَنُيَسِّرُهُۥ لِلْعُسْرَىٰ"},{"id":6069,"verse_key":"92:11","text_uthmani":"وَمَا يُغْنِى عَنْهُ مَالُهُۥٓ إِذَا تَرَدَّىٰٓ"},{"id":6070,"verse_key":"92:12","text_uthmani":"إِنَّ عَلَيْنَا لَلْهُدَىٰ"},{"id":6071,"verse_key":"92:13","text_uthmani":"وَإِنَّ لَنَا لَلْـَٔاخِرَةَ وَٱلْأُولَىٰ"},{"id":6072,"verse_key":"92:14","text_uthmani":"فَأَنذَرْتُكُمْ نَارًا تَلَظَّىٰ"}]