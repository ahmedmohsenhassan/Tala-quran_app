[{"id":3092,"verse_key":"26:160","text_uthmani":"كَذَّبَتْ قَوْمُ لُوطٍ ٱلْمُرْسَلِينَ"},{"id":3093,"verse_key":"26:161","text_uthmani":"إِذْ قَالَ لَهُمْ أَخُوهُمْ لُوطٌ أَلَا تَتَّقُونَ"},{"id":3094,"verse_key":"26:162","text_uthmani":"إِنِّى لَكُمْ رَسُولٌ أَمِينٌ"},{"id":3095,"verse_key":"26:163","text_uthmani":"فَٱتَّقُوا۟ ٱللَّهَ وَأَطِيعُونِ"},{"id":3096,"verse_key":"26:164","text_uthmani":"وَمَآ أَسْـَٔلُكُمْ عَلَيْهِ مِنْ أَجْرٍ ۖ إِنْ أَجْرِىَ إِلَّا عَلَىٰ رَبِّ ٱلْعَـٰلَمِينَ"},{"id":3097,"verse_key":"26:165","text_uthmani":"أَتَأْتُونَ ٱلذُّكْرَانَ مِنَ ٱلْعَـٰلَمِينَ"},{"id":3098,"verse_key":"26:166","text_uthmani":"وَتَذَرُونَ مَا خَلَقَ لَكُمْ رَبُّكُم مِّنْ أَزْوَٰجِكُم ۚ بَلْ أَنتُمْ قَوْمٌ عَادُونَ"},{"id":3099,"verse_key":"26:167","text_uthmani":"قَالُوا۟ لَئِن لَّمْ تَنتَهِ يَـٰلُوطُ لَتَكُونَنَّ مِنَ ٱلْمُخْرَجِينَ"},{"id":3100,"verse_key":"26:168","text_uthmani":"قَالَ إِنِّى لِعَمَلِكُم مِّنَ ٱلْقَالِينَ"},{"id":3101,"verse_key":"26:169","text_uthmani":"رَبِّ نَجِّنِى وَأَهْلِى مِمَّا يَعْمَلُونَ"},{"id":3102,"verse_key":"26:170","text_uthmani":"فَنَجَّيْنَـٰهُ وَأَهْلَهُۥٓ أَجْمَعِينَ"},{"id":3103,"verse_key":"26:171","text_uthmani":"إِلَّا عَجُوزًا فِى ٱلْغَـٰبِرِينَ"},{"id":3104,"verse_key":"26:172","text_uthmani":"ثُمَّ دَمَّرْنَا ٱلْـَٔاخَرِينَ"},{"id":3105,"verse_key":"26:173","text_uthmani":"وَأَمْطَرْنَا عَلَيْهِم مَّطَرًا ۖ فَسَآءَ مَطَرُ ٱلْمُنذَرِينَ"},{"id":3106,"verse_key":"26:174","text_uthmani":"إِنَّ فِى ذَٰلِكَ لَـَٔايَةً ۖ وَمَا كَانَ أَكْثَرُهُم مُّؤْمِنِينَ"},{"id":3107,"verse_key":"26:175","text_uthmani":"وَإِنَّ رَبَّكَ لَهُوَ ٱلْعَزِيزُ ٱلرَّحِيمُ"},{"id":3108,"verse_key":"26:176","text_uthmani":"كَذَّبَ أَصْحَـٰبُ لْـَٔيْكَةِ ٱلْمُرْسَلِينَ"},{"id":3109,"verse_key":"26:177","text_uthmani":"إِذْ قَالَ لَهُمْ شُعَيْبٌ أَلَا تَتَّقُونَ"},{"id":3110,"verse_key":"26:178","text_uthmani":"إِنِّى لَكُمْ رَسُولٌ أَمِينٌ"},{"id":3111,"verse_key":"26:179","text_uthmani":"فَٱتَّقُوا۟ ٱللَّهَ وَأَطِيعُونِ"},{"id":3112,"verse_key":"26:180","text_uthmani":"وَمَآ أَسْـَٔلُكُمْ عَلَيْهِ مِنْ أَجْرٍ ۖ إِنْ أَجْرِىَ إِلَّا عَلَىٰ رَبِّ ٱلْعَـٰلَمِينَ"},{"id":3113,"verse_key":"26:181","text_uthmani":"۞ أَوْفُوا۟ ٱلْكَيْلَ وَلَا تَكُونُوا۟ مِنَ ٱلْمُخْسِرِينَ"},{"id":3114,"verse_key":"26:182","text_uthmani":"وَزِنُوا۟ بِٱلْقِسْطَاسِ ٱلْمُسْتَقِيمِ"},{"id":3115,"verse_key":"26:183","text_uthmani":"وَلَا تَبْخَسُوا۟ ٱلنَّاسَ أَشْيَآءَهُمْ وَلَا تَعْثَوْا۟ فِى ٱلْأَرْضِ مُفْسِدِينَ"}]