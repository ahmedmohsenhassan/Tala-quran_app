[{"id":5994,"verse_key":"89:1","text_uthmani":" وَٱلْفَجْرِ"},{"id":5995,"verse_key":"89:2","text_uthmani":"وَلَيَالٍ عَشْرٍ"},{"id":5996,"verse_key":"89:3","text_uthmani":"وَٱلشَّفْعِ وَٱلْوَتْرِ"},{"id":5997,"verse_key":"89:4","text_uthmani":"وَٱلَّيْلِ إِذَا يَسْرِ"},{"id":5998,"verse_key":"89:5","text_uthmani":"هَلْ فِى ذَٰلِكَ قَسَمٌ لِّذِى حِجْرٍ"},{"id":5999,"verse_key":"89:6","text_uthmani":"أَلَمْ تَرَ كَيْفَ فَعَلَ رَبُّكَ بِعَادٍ"},{"id":6000,"verse_key":"89:7","text_uthmani":"إِرَمَ ذَاتِ ٱلْعِمَادِ"},{"id":6001,"verse_key":"89:8","text_uthmani":"ٱلَّتِى لَمْ يُخْلَقْ مِثْلُهَا فِى ٱلْبِلَـٰدِ"},{"id":6002,"verse_key":"89:9","text_uthmani":"وَثَمُودَ ٱلَّذِينَ جَابُوا۟ ٱلصَّخْرَ بِٱلْوَادِ"},{"id":6003,"verse_key":"89:10","text_uthmani":"وَفِرْعَوْنَ ذِى ٱلْأَوْتَادِ"},{"id":6004,"verse_key":"89:11","text_uthmani":"ٱلَّذِينَ طَغَوْا۟ فِى ٱلْبِلَـٰدِ"},{"id":6005,"verse_key":"89:12","text_uthmani":"فَأَكْثَرُوا۟ فِيهَا ٱلْفَسَادَ"},{"id":6006,"verse_key":"89:13","text_uthmani":"فَصَبَّ عَلَيْهِمْ رَبُّكَ سَوْطَ عَذَابٍ"},{"id":6007,"verse_key":"89:14","text_uthmani":"إِنَّ رَبَّكَ لَبِٱلْمِرْصَادِ"},{"id":6008,"verse_key":"89:15","text_uthmani":"فَأَمَّا ٱلْإِنسَـٰنُ إِذَا مَا ٱبْتَلَىٰهُ رَبُّهُۥ فَأَكْرَمَهُۥ وَنَعَّمَهُۥ فَيَقُولُ رَبِّىٓ أَكْرَمَنِ"},{"id":6009,"verse_key":"89:16","text_uthmani":"وَأَمَّآ إِذَا مَا ٱبْتَلَىٰهُ فَقَدَرَ عَلَيْهِ رِزْقَهُۥ فَيَقُولُ رَبِّىٓ أَهَـٰنَنِ"},{"id":6010,"verse_key":"89:17","text_uthmani":"كَلَّا ۖ بَل لَّا تُكْرِمُونَ ٱلْيَتِيمَ"},{"id":6011,"verse_key":"89:18","text_uthmani":"وَلَا تَحَـٰٓضُّونَ عَلَىٰ طَعَامِ ٱلْمِسْكِينِ"},{"id":6012,"verse_key":"89:19","text_uthmani":"وَتَأْكُلُونَ ٱلتُّرَاثَ أَكْلًا لَّمًّا"},{"id":6013,"verse_key":"89:20","text_uthmani":"وَتُحِبُّونَ ٱلْمَالَ حُبًّا جَمًّا"},{"id":6014,"verse_key":"89:21","text_uthmani":"كَلَّآ إِذَا دُكَّتِ ٱلْأَرْضُ دَكًّا دَكًّا"},{"id":6015,"verse_key":"89:22","text_uthmani":"وَجَآءَ رَبُّكَ وَٱلْمَلَكُ صَفًّا صَفًّا"},{"id":6016,"verse_key":"89:23","text_uthmani":"وَجِا۟ىٓءَ يَوْمَئِذٍۭ بِجَهَنَّمَ ۚ يَوْمَئِذٍ يَتَذَكَّرُ ٱلْإِنسَـٰنُ وَأَنَّىٰ لَهُ ٱلذِّكْرَىٰ"}]