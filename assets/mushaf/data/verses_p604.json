[{"id":6222,"verse_key":"112:1","text_uthmani":" قُلْ هُوَ ٱللَّهُ أَحَدٌ"},{"id":6223,"verse_key":"112:2","text_uthmani":"ٱللَّهُ ٱلصَّمَدُ"},{"id":6224,"verse_key":"112:3","text_uthmani":"لَمْ يَلِدْ وَلَمْ يُولَدْ"},{"id":6225,"verse_key":"112:4","text_uthmani":"وَلَمْ يَكُن لَّهُۥ كُفُوًا أَحَدٌۢ"},{"id":6226,"verse_key":"113:1","text_uthmani":" قُلْ أَعُوذُ بِرَبِّ ٱلْفَلَقِ"},{"id":6227,"verse_key":"113:2","text_uthmani":"مِن شَرِّ مَا خَلَقَ"},{"id":6228,"verse_key":"113:3","text_uthmani":"وَمِن شَرِّ غَاسِقٍ إِذَا وَقَبَ"},{"id":6229,"verse_key":"113:4","text_uthmani":"وَمِن شَرِّ ٱلنَّفَّـٰثَـٰتِ فِى ٱلْعُقَدِ"},{"id":6230,"verse_key":"113:5","text_uthmani":"وَمِن شَرِّ حَاسِدٍ إِذَا حَسَدَ"},{"id":6231,"verse_key":"114:1","text_uthmani":" قُلْ أَعُوذُ بِرَبِّ ٱلنَّاسِ"},{"id":6232,"verse_key":"114:2","text_uthmani":"مَلِكِ ٱلنَّاسِ"},{"id":6233,"verse_key":"114:3","text_uthmani":"إِلَـٰهِ ٱلنَّاسِ"},{"id":6234,"verse_key":"114:4","text_uthmani":"مِن شَرِّ ٱلْوَسْوَاسِ ٱلْخَنَّاسِ"},{"id":6235,"verse_key":"114:5","text_uthmani":"ٱلَّذِى يُوَسْوِسُ فِى صُدُورِ ٱلنَّاسِ"},{"id":6236,"verse_key":"114:6","text_uthmani":"مِنَ ٱلْجِنَّةِ وَٱلنَّاسِ"}]