[{"id":3044,"verse_key":"26:112","text_uthmani":"قَالَ وَمَا عِلْمِى بِمَا كَانُوا۟ يَعْمَلُونَ"},{"id":3045,"verse_key":"26:113","text_uthmani":"إِنْ حِسَابُهُمْ إِلَّا عَلَىٰ رَبِّى ۖ لَوْ تَشْعُرُونَ"},{"id":3046,"verse_key":"26:114","text_uthmani":"وَمَآ أَنَا۠ بِطَارِدِ ٱلْمُؤْمِنِينَ"},{"id":3047,"verse_key":"26:115","text_uthmani":"إِنْ أَنَا۠ إِلَّا نَذِيرٌ مُّبِينٌ"},{"id":3048,"verse_key":"26:116","text_uthmani":"قَالُوا۟ لَئِن لَّمْ تَنتَهِ يَـٰنُوحُ لَتَكُونَنَّ مِنَ ٱلْمَرْجُومِينَ"},{"id":3049,"verse_key":"26:117","text_uthmani":"قَالَ رَبِّ إِنَّ قَوْمِى كَذَّبُونِ"},{"id":3050,"verse_key":"26:118","text_uthmani":"فَٱفْتَحْ بَيْنِى وَبَيْنَهُمْ فَتْحًا وَنَجِّنِى وَمَن مَّعِىَ مِنَ ٱلْمُؤْمِنِينَ"},{"id":3051,"verse_key":"26:119","text_uthmani":"فَأَنجَيْنَـٰهُ وَمَن مَّعَهُۥ فِى ٱلْفُلْكِ ٱلْمَشْحُونِ"},{"id":3052,"verse_key":"26:120","text_uthmani":"ثُمَّ أَغْرَقْنَا بَعْدُ ٱلْبَاقِينَ"},{"id":3053,"verse_key":"26:121","text_uthmani":"إِنَّ فِى ذَٰلِكَ لَـَٔايَةً ۖ وَمَا كَانَ أَكْثَرُهُم مُّؤْمِنِينَ"},{"id":3054,"verse_key":"26:122","text_uthmani":"وَإِنَّ رَبَّكَ لَهُوَ ٱلْعَزِيزُ ٱلرَّحِيمُ"},{"id":3055,"verse_key":"26:123","text_uthmani":"كَذَّبَتْ عَادٌ ٱلْمُرْسَلِينَ"},{"id":3056,"verse_key":"26:124","text_uthmani":"إِذْ قَالَ لَهُمْ أَخُوهُمْ هُودٌ أَلَا تَتَّقُونَ"},{"id":3057,"verse_key":"26:125","text_uthmani":"إِنِّى لَكُمْ رَسُولٌ أَمِينٌ"},{"id":3058,"verse_key":"26:126","text_uthmani":"فَٱتَّقُوا۟ ٱللَّهَ وَأَطِيعُونِ"},{"id":3059,"verse_key":"26:127","text_uthmani":"وَمَآ أَسْـَٔلُكُمْ عَلَيْهِ مِنْ أَجْرٍ ۖ إِنْ أَجْرِىَ إِلَّا عَلَىٰ رَبِّ ٱلْعَـٰلَمِينَ"},{"id":3060,"verse_key":"26:128","text_uthmani":"أَتَبْنُونَ بِكُلِّ رِيعٍ ءَايَةً تَعْبَثُونَ"},{"id":3061,"verse_key":"26:129","text_uthmani":"وَتَتَّخِذُونَ مَصَانِعَ لَعَلَّكُمْ تَخْلُدُونَ"},{"id":3062,"verse_key":"26:130","text_uthmani":"وَإِذَا بَطَشْتُم بَطَشْتُمْ جَبَّارِينَ"},{"id":3063,"verse_key":"26:131","text_uthmani":"فَٱتَّقُوا۟ ٱللَّهَ وَأَطِيعُونِ"},{"id":3064,"verse_key":"26:132","text_uthmani":"وَٱتَّقُوا۟ ٱلَّذِىٓ أَمَدَّكُم بِمَا تَعْلَمُونَ"},{"id":3065,"verse_key":"26:133","text_uthmani":"أَمَدَّكُم بِأَنْعَـٰمٍ وَبَنِينَ"},{"id":3066,"verse_key":"26:134","text_uthmani":"وَجَنَّـٰتٍ وَعُيُونٍ"},{"id":3067,"verse_key":"26:135","text_uthmani":"إِنِّىٓ أَخَافُ عَلَيْكُمْ عَذَابَ يَوْمٍ عَظِيمٍ"},{"id":3068,"verse_key":"26:136","text_uthmani":"قَالُوا۟ سَوَآءٌ عَلَيْنَآ أَوَعَظْتَ أَمْ لَمْ تَكُن مِّنَ ٱلْوَٰعِظِينَ"}]