[{"id":5386,"verse_key":"70:11","text_uthmani":"يُبَصَّرُونَهُمْ ۚ يَوَدُّ ٱلْمُجْرِمُ لَوْ يَفْتَدِى مِنْ عَذَابِ يَوْمِئِذٍۭ بِبَنِيهِ"},{"id":5387,"verse_key":"70:12","text_uthmani":"وَصَـٰحِبَتِهِۦ وَأَخِيهِ"},{"id":5388,"verse_key":"70:13","text_uthmani":"وَفَصِيلَتِهِ ٱلَّتِى تُـْٔوِيهِ"},{"id":5389,"verse_key":"70:14","text_uthmani":"وَمَن فِى ٱلْأَرْضِ جَمِيعًا ثُمَّ يُنجِيهِ"},{"id":5390,"verse_key":"70:15","text_uthmani":"كَلَّآ ۖ إِنَّهَا لَظَىٰ"},{"id":5391,"verse_key":"70:16","text_uthmani":"نَزَّاعَةً لِّلشَّوَىٰ"},{"id":5392,"verse_key":"70:17","text_uthmani":"تَدْعُوا۟ مَنْ أَدْبَرَ وَتَوَلَّىٰ"},{"id":5393,"verse_key":"70:18","text_uthmani":"وَجَمَعَ فَأَوْعَىٰٓ"},{"id":5394,"verse_key":"70:19","text_uthmani":"۞ إِنَّ ٱلْإِنسَـٰنَ خُلِقَ هَلُوعًا"},{"id":5395,"verse_key":"70:20","text_uthmani":"إِذَا مَسَّهُ ٱلشَّرُّ جَزُوعًا"},{"id":5396,"verse_key":"70:21","text_uthmani":"وَإِذَا مَسَّهُ ٱلْخَيْرُ مَنُوعًا"},{"id":5397,"verse_key":"70:22","text_uthmani":"إِلَّا ٱلْمُصَلِّينَ"},{"id":5398,"verse_key":"70:23","text_uthmani":"ٱلَّذِينَ هُمْ عَلَىٰ صَلَاتِهِمْ دَآئِمُونَ"},{"id":5399,"verse_key":"70:24","text_uthmani":"وَٱلَّذِينَ فِىٓ أَمْوَٰلِهِمْ حَقٌّ مَّعْلُومٌ"},{"id":5400,"verse_key":"70:25","text_uthmani":"لِّلسَّآئِلِ وَٱلْمَحْرُومِ"},{"id":5401,"verse_key":"70:26","text_uthmani":"وَٱلَّذِينَ يُصَدِّقُونَ بِيَوْمِ ٱلدِّينِ"},{"id":5402,"verse_key":"70:27","text_uthmani":"وَٱلَّذِينَ هُم مِّنْ عَذَابِ رَبِّهِم مُّشْفِقُونَ"},{"id":5403,"verse_key":"70:28","text_uthmani":"إِنَّ عَذَابَ رَبِّهِمْ غَيْرُ مَأْمُونٍ"},{"id":5404,"verse_key":"70:29","text_uthmani":"وَٱلَّذِينَ هُمْ لِفُرُوجِهِمْ حَـٰفِظُونَ"},{"id":5405,"verse_key":"70:30","text_uthmani":"إِلَّا عَلَىٰٓ أَزْوَٰجِهِمْ أَوْ مَا مَلَكَتْ أَيْمَـٰنُهُمْ فَإِنَّهُمْ غَيْرُ مَلُومِينَ"},{"id":5406,"verse_key":"70:31","text_uthmani":"فَمَنِ ٱبْتَغَىٰ وَرَآءَ ذَٰلِكَ فَأُو۟لَـٰٓئِكَ هُمُ ٱلْعَادُونَ"},{"id":5407,"verse_key":"70:32","text_uthmani":"وَٱلَّذِينَ هُمْ لِأَمَـٰنَـٰتِهِمْ وَعَهْدِهِمْ رَٰعُونَ"},{"id":5408,"verse_key":"70:33","text_uthmani":"وَٱلَّذِينَ هُم بِشَهَـٰدَٰتِهِمْ قَآئِمُونَ"},{"id":5409,"verse_key":"70:34","text_uthmani":"وَٱلَّذِينَ هُمْ عَلَىٰ صَلَاتِهِمْ يُحَافِظُونَ"},{"id":5410,"verse_key":"70:35","text_uthmani":"أُو۟لَـٰٓئِكَ فِى جَنَّـٰتٍ مُّكْرَمُونَ"},{"id":5411,"verse_key":"70:36","text_uthmani":"فَمَالِ ٱلَّذِينَ كَفَرُوا۟ قِبَلَكَ مُهْطِعِينَ"},{"id":5412,"verse_key":"70:37","text_uthmani":"عَنِ ٱلْيَمِينِ وَعَنِ ٱلشِّمَالِ عِزِينَ"},{"id":5413,"verse_key":"70:38","text_uthmani":"أَيَطْمَعُ كُلُّ ٱمْرِئٍ مِّنْهُمْ أَن يُدْخَلَ جَنَّةَ نَعِيمٍ"},{"id":5414,"verse_key":"70:39","text_uthmani":"كَلَّآ ۖ إِنَّا خَلَقْنَـٰهُم مِّمَّا يَعْلَمُونَ"}]