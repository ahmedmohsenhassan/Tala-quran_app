[{"id":6138,"verse_key":"98:8","text_uthmani":"جَزَآؤُهُمْ عِندَ رَبِّهِمْ جَنَّـٰتُ عَدْنٍ تَجْرِى مِن تَحْتِهَا ٱلْأَنْهَـٰرُ خَـٰلِدِينَ فِيهَآ أَبَدًا ۖ رَّضِىَ ٱللَّهُ عَنْهُمْ وَرَضُوا۟ عَنْهُ ۚ ذَٰلِكَ لِمَنْ خَشِىَ رَبَّهُۥ"},{"id":6139,"verse_key":"99:1","text_uthmani":" إِذَا زُلْزِلَتِ ٱلْأَرْضُ زِلْزَالَهَا"},{"id":6140,"verse_key":"99:2","text_uthmani":"وَأَخْرَجَتِ ٱلْأَرْضُ أَثْقَالَهَا"},{"id":6141,"verse_key":"99:3","text_uthmani":"وَقَالَ ٱلْإِنسَـٰنُ مَا لَهَا"},{"id":6142,"verse_key":"99:4","text_uthmani":"يَوْمَئِذٍ تُحَدِّثُ أَخْبَارَهَا"},{"id":6143,"verse_key":"99:5","text_uthmani":"بِأَنَّ رَبَّكَ أَوْحَىٰ لَهَا"},{"id":6144,"verse_key":"99:6","text_uthmani":"يَوْمَئِذٍ يَصْدُرُ ٱلنَّاسُ أَشْتَاتًا لِّيُرَوْا۟ أَعْمَـٰلَهُمْ"},{"id":6145,"verse_key":"99:7","text_uthmani":"فَمَن يَعْمَلْ مِثْقَالَ ذَرَّةٍ خَيْرًا يَرَهُۥ"},{"id":6146,"verse_key":"99:8","text_uthmani":"وَمَن يَعْمَلْ مِثْقَالَ ذَرَّةٍ شَرًّا يَرَهُۥ"},{"id":6147,"verse_key":"100:1","text_uthmani":" وَٱلْعَـٰدِيَـٰتِ ضَبْحًا"},{"id":6148,"verse_key":"100:2","text_uthmani":"فَٱلْمُورِيَـٰتِ قَدْحًا"},{"id":6149,"verse_key":"100:3","text_uthmani":"فَٱلْمُغِيرَٰتِ صُبْحًا"},{"id":6150,"verse_key":"100:4","text_uthmani":"فَأَثَرْنَ بِهِۦ نَقْعًا"},{"id":6151,"verse_key":"100:5","text_uthmani":"فَوَسَطْنَ بِهِۦ جَمْعًا"},{"id":6152,"verse_key":"100:6","text_uthmani":"إِنَّ ٱلْإِنسَـٰنَ لِرَبِّهِۦ لَكَنُودٌ"},{"id":6153,"verse_key":"100:7","text_uthmani":"وَإِنَّهُۥ عَلَىٰ ذَٰلِكَ لَشَهِيدٌ"},{"id":6154,"verse_key":"100:8","text_uthmani":"وَإِنَّهُۥ لِحُبِّ ٱلْخَيْرِ لَشَدِيدٌ"},{"id":6155,"verse_key":"100:9","text_uthmani":"۞ أَفَلَا يَعْلَمُ إِذَا بُعْثِرَ مَا فِى ٱلْقُبُورِ"}]