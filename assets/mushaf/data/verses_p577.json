[{"id":5543,"verse_key":"74:48","text_uthmani":"فَمَا تَنفَعُهُمْ شَفَـٰعَةُ ٱلشَّـٰفِعِينَ"},{"id":5544,"verse_key":"74:49","text_uthmani":"فَمَا لَهُمْ عَنِ ٱلتَّذْكِرَةِ مُعْرِضِينَ"},{"id":5545,"verse_key":"74:50","text_uthmani":"كَأَنَّهُمْ حُمُرٌ مُّسْتَنفِرَةٌ"},{"id":5546,"verse_key":"74:51","text_uthmani":"فَرَّتْ مِن قَسْوَرَةٍۭ"},{"id":5547,"verse_key":"74:52","text_uthmani":"بَلْ يُرِيدُ كُلُّ ٱمْرِئٍ مِّنْهُمْ أَن يُؤْتَىٰ صُحُفًا مُّنَشَّرَةً"},{"id":5548,"verse_key":"74:53","text_uthmani":"كَلَّا ۖ بَل لَّا يَخَافُونَ ٱلْـَٔاخِرَةَ"},{"id":5549,"verse_key":"74:54","text_uthmani":"كَلَّآ إِنَّهُۥ تَذْكِرَةٌ"},{"id":5550,"verse_key":"74:55","text_uthmani":"فَمَن شَآءَ ذَكَرَهُۥ"},{"id":5551,"verse_key":"74:56","text_uthmani":"وَمَا يَذْكُرُونَ إِلَّآ أَن يَشَآءَ ٱللَّهُ ۚ هُوَ أَهْلُ ٱلتَّقْوَىٰ وَأَهْلُ ٱلْمَغْفِرَةِ"},{"id":5552,"verse_key":"75:1","text_uthmani":" لَآ أُقْسِمُ بِيَوْمِ ٱلْقِيَـٰمَةِ"},{"id":5553,"verse_key":"75:2","text_uthmani":"وَلَآ أُقْسِمُ بِٱلنَّفْسِ ٱللَّوَّامَةِ"},{"id":5554,"verse_key":"75:3","text_uthmani":"أَيَحْسَبُ ٱلْإِنسَـٰنُ أَلَّن نَّجْمَعَ عِظَامَهُۥ"},{"id":5555,"verse_key":"75:4","text_uthmani":"بَلَىٰ قَـٰدِرِينَ عَلَىٰٓ أَن نُّسَوِّىَ بَنَانَهُۥ"},{"id":5556,"verse_key":"75:5","text_uthmani":"بَلْ يُرِيدُ ٱلْإِنسَـٰنُ لِيَفْجُرَ أَمَامَهُۥ"},{"id":5557,"verse_key":"75:6","text_uthmani":"يَسْـَٔلُ أَيَّانَ يَوْمُ ٱلْقِيَـٰمَةِ"},{"id":5558,"verse_key":"75:7","text_uthmani":"فَإِذَا بَرِقَ ٱلْبَصَرُ"},{"id":5559,"verse_key":"75:8","text_uthmani":"وَخَسَفَ ٱلْقَمَرُ"},{"id":5560,"verse_key":"75:9","text_uthmani":"وَجُمِعَ ٱلشَّمْسُ وَٱلْقَمَرُ"},{"id":5561,"verse_key":"75:10","text_uthmani":"يَقُولُ ٱلْإِنسَـٰنُ يَوْمَئِذٍ أَيْنَ ٱلْمَفَرُّ"},{"id":5562,"verse_key":"75:11","text_uthmani":"كَلَّا لَا وَزَرَ"},{"id":5563,"verse_key":"75:12","text_uthmani":"إِلَىٰ رَبِّكَ يَوْمَئِذٍ ٱلْمُسْتَقَرُّ"},{"id":5564,"verse_key":"75:13","text_uthmani":"يُنَبَّؤُا۟ ٱلْإِنسَـٰنُ يَوْمَئِذٍۭ بِمَا قَدَّمَ وَأَخَّرَ"},{"id":5565,"verse_key":"75:14","text_uthmani":"بَلِ ٱلْإِنسَـٰنُ عَلَىٰ نَفْسِهِۦ بَصِيرَةٌ"},{"id":5566,"verse_key":"75:15","text_uthmani":"وَلَوْ أَلْقَىٰ مَعَاذِيرَهُۥ"},{"id":5567,"verse_key":"75:16","text_uthmani":"لَا تُحَرِّكْ بِهِۦ لِسَانَكَ لِتَعْجَلَ بِهِۦٓ"},{"id":5568,"verse_key":"75:17","text_uthmani":"إِنَّ عَلَيْنَا جَمْعَهُۥ وَقُرْءَانَهُۥ"},{"id":5569,"verse_key":"75:18","text_uthmani":"فَإِذَا قَرَأْنَـٰهُ فَٱتَّبِعْ قُرْءَانَهُۥ"},{"id":5570,"verse_key":"75:19","text_uthmani":"ثُمَّ إِنَّ عَلَيْنَا بَيَانَهُۥ"}]