[{"id":5056,"verse_key":"56:77","text_uthmani":"إِنَّهُۥ لَقُرْءَانٌ كَرِيمٌ"},{"id":5057,"verse_key":"56:78","text_uthmani":"فِى كِتَـٰبٍ مَّكْنُونٍ"},{"id":5058,"verse_key":"56:79","text_uthmani":"لَّا يَمَسُّهُۥٓ إِلَّا ٱلْمُطَهَّرُونَ"},{"id":5059,"verse_key":"56:80","text_uthmani":"تَنزِيلٌ مِّن رَّبِّ ٱلْعَـٰلَمِينَ"},{"id":5060,"verse_key":"56:81","text_uthmani":"أَفَبِهَـٰذَا ٱلْحَدِيثِ أَنتُم مُّدْهِنُونَ"},{"id":5061,"verse_key":"56:82","text_uthmani":"وَتَجْعَلُونَ رِزْقَكُمْ أَنَّكُمْ تُكَذِّبُونَ"},{"id":5062,"verse_key":"56:83","text_uthmani":"فَلَوْلَآ إِذَا بَلَغَتِ ٱلْحُلْقُومَ"},{"id":5063,"verse_key":"56:84","text_uthmani":"وَأَنتُمْ حِينَئِذٍ تَنظُرُونَ"},{"id":5064,"verse_key":"56:85","text_uthmani":"وَنَحْنُ أَقْرَبُ إِلَيْهِ مِنكُمْ وَلَـٰكِن لَّا تُبْصِرُونَ"},{"id":5065,"verse_key":"56:86","text_uthmani":"فَلَوْلَآ إِن كُنتُمْ غَيْرَ مَدِينِينَ"},{"id":5066,"verse_key":"56:87","text_uthmani":"تَرْجِعُونَهَآ إِن كُنتُمْ صَـٰدِقِينَ"},{"id":5067,"verse_key":"56:88","text_uthmani":"فَأَمَّآ إِن كَانَ مِنَ ٱلْمُقَرَّبِينَ"},{"id":5068,"verse_key":"56:89","text_uthmani":"فَرَوْحٌ وَرَيْحَانٌ وَجَنَّتُ نَعِيمٍ"},{"id":5069,"verse_key":"56:90","text_uthmani":"وَأَمَّآ إِن كَانَ مِنْ أَصْحَـٰبِ ٱلْيَمِينِ"},{"id":5070,"verse_key":"56:91","text_uthmani":"فَسَلَـٰمٌ لَّكَ مِنْ أَصْحَـٰبِ ٱلْيَمِينِ"},{"id":5071,"verse_key":"56:92","text_uthmani":"وَأَمَّآ إِن كَانَ مِنَ ٱلْمُكَذِّبِينَ ٱلضَّآلِّينَ"},{"id":5072,"verse_key":"56:93","text_uthmani":"فَنُزُلٌ مِّنْ حَمِيمٍ"},{"id":5073,"verse_key":"56:94","text_uthmani":"وَتَصْلِيَةُ جَحِيمٍ"},{"id":5074,"verse_key":"56:95","text_uthmani":"إِنَّ هَـٰذَا لَهُوَ حَقُّ ٱلْيَقِينِ"},{"id":5075,"verse_key":"56:96","text_uthmani":"فَسَبِّحْ بِٱسْمِ رَبِّكَ ٱلْعَظِيمِ"},{"id":5076,"verse_key":"57:1","text_uthmani":" سَبَّحَ لِلَّهِ مَا فِى ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضِ ۖ وَهُوَ ٱلْعَزِيزُ ٱلْحَكِيمُ"},{"id":5077,"verse_key":"57:2","text_uthmani":"لَهُۥ مُلْكُ ٱلسَّمَـٰوَٰتِ وَٱلْأَرْضِ ۖ يُحْىِۦ وَيُمِيتُ ۖ وَهُوَ عَلَىٰ كُلِّ شَىْءٍ قَدِيرٌ"},{"id":5078,"verse_key":"57:3","text_uthmani":"هُوَ ٱلْأَوَّلُ وَٱلْـَٔاخِرُ وَٱلظَّـٰهِرُ وَٱلْبَاطِنُ ۖ وَهُوَ بِكُلِّ شَىْءٍ عَلِيمٌ"}]