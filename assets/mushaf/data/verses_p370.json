[{"id":2993,"verse_key":"26:61","text_uthmani":"فَلَمَّا تَرَٰٓءَا ٱلْجَمْعَانِ قَالَ أَصْحَـٰبُ مُوسَىٰٓ إِنَّا لَمُدْرَكُونَ"},{"id":2994,"verse_key":"26:62","text_uthmani":"قَالَ كَلَّآ ۖ إِنَّ مَعِىَ رَبِّى سَيَهْدِينِ"},{"id":2995,"verse_key":"26:63","text_uthmani":"فَأَوْحَيْنَآ إِلَىٰ مُوسَىٰٓ أَنِ ٱضْرِب بِّعَصَاكَ ٱلْبَحْرَ ۖ فَٱنفَلَقَ فَكَانَ كُلُّ فِرْقٍ كَٱلطَّوْدِ ٱلْعَظِيمِ"},{"id":2996,"verse_key":"26:64","text_uthmani":"وَأَزْلَفْنَا ثَمَّ ٱلْـَٔاخَرِينَ"},{"id":2997,"verse_key":"26:65","text_uthmani":"وَأَنجَيْنَا مُوسَىٰ وَمَن مَّعَهُۥٓ أَجْمَعِينَ"},{"id":2998,"verse_key":"26:66","text_uthmani":"ثُمَّ أَغْرَقْنَا ٱلْـَٔاخَرِينَ"},{"id":2999,"verse_key":"26:67","text_uthmani":"إِنَّ فِى ذَٰلِكَ لَـَٔايَةً ۖ وَمَا كَانَ أَكْثَرُهُم مُّؤْمِنِينَ"},{"id":3000,"verse_key":"26:68","text_uthmani":"وَإِنَّ رَبَّكَ لَهُوَ ٱلْعَزِيزُ ٱلرَّحِيمُ"},{"id":3001,"verse_key":"26:69","text_uthmani":"وَٱتْلُ عَلَيْهِمْ نَبَأَ إِبْرَٰهِيمَ"},{"id":3002,"verse_key":"26:70","text_uthmani":"إِذْ قَالَ لِأَبِيهِ وَقَوْمِهِۦ مَا تَعْبُدُونَ"},{"id":3003,"verse_key":"26:71","text_uthmani":"قَالُوا۟ نَعْبُدُ أَصْنَامًا فَنَظَلُّ لَهَا عَـٰكِفِينَ"},{"id":3004,"verse_key":"26:72","text_uthmani":"قَالَ هَلْ يَسْمَعُونَكُمْ إِذْ تَدْعُونَ"},{"id":3005,"verse_key":"26:73","text_uthmani":"أَوْ يَنفَعُونَكُمْ أَوْ يَضُرُّونَ"},{"id":3006,"verse_key":"26:74","text_uthmani":"قَالُوا۟ بَلْ وَجَدْنَآ ءَابَآءَنَا كَذَٰلِكَ يَفْعَلُونَ"},{"id":3007,"verse_key":"26:75","text_uthmani":"قَالَ أَفَرَءَيْتُم مَّا كُنتُمْ تَعْبُدُونَ"},{"id":3008,"verse_key":"26:76","text_uthmani":"أَنتُمْ وَءَابَآؤُكُمُ ٱلْأَقْدَمُونَ"},{"id":3009,"verse_key":"26:77","text_uthmani":"فَإِنَّهُمْ عَدُوٌّ لِّىٓ إِلَّا رَبَّ ٱلْعَـٰلَمِينَ"},{"id":3010,"verse_key":"26:78","text_uthmani":"ٱلَّذِى خَلَقَنِى فَهُوَ يَهْدِينِ"},{"id":3011,"verse_key":"26:79","text_uthmani":"وَٱلَّذِى هُوَ يُطْعِمُنِى وَيَسْقِينِ"},{"id":3012,"verse_key":"26:80","text_uthmani":"وَإِذَا مَرِضْتُ فَهُوَ يَشْفِينِ"},{"id":3013,"verse_key":"26:81","text_uthmani":"وَٱلَّذِى يُمِيتُنِى ثُمَّ يُحْيِينِ"},{"id":3014,"verse_key":"26:82","text_uthmani":"وَٱلَّذِىٓ أَطْمَعُ أَن يَغْفِرَ لِى خَطِيٓـَٔتِى يَوْمَ ٱلدِّينِ"},{"id":3015,"verse_key":"26:83","text_uthmani":"رَبِّ هَبْ لِى حُكْمًا وَأَلْحِقْنِى بِٱلصَّـٰلِحِينَ"}]