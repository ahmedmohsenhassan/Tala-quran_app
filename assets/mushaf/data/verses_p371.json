[{"id":3016,"verse_key":"26:84","text_uthmani":"وَٱجْعَل لِّى لِسَانَ صِدْقٍ فِى ٱلْـَٔاخِرِينَ"},{"id":3017,"verse_key":"26:85","text_uthmani":"وَٱجْعَلْنِى مِن وَرَثَةِ جَنَّةِ ٱلنَّعِيمِ"},{"id":3018,"verse_key":"26:86","text_uthmani":"وَٱغْفِرْ لِأَبِىٓ إِنَّهُۥ كَانَ مِنَ ٱلضَّآلِّينَ"},{"id":3019,"verse_key":"26:87","text_uthmani":"وَلَا تُخْزِنِى يَوْمَ يُبْعَثُونَ"},{"id":3020,"verse_key":"26:88","text_uthmani":"يَوْمَ لَا يَنفَعُ مَالٌ وَلَا بَنُونَ"},{"id":3021,"verse_key":"26:89","text_uthmani":"إِلَّا مَنْ أَتَى ٱللَّهَ بِقَلْبٍ سَلِيمٍ"},{"id":3022,"verse_key":"26:90","text_uthmani":"وَأُزْلِفَتِ ٱلْجَنَّةُ لِلْمُتَّقِينَ"},{"id":3023,"verse_key":"26:91","text_uthmani":"وَبُرِّزَتِ ٱلْجَحِيمُ لِلْغَاوِينَ"},{"id":3024,"verse_key":"26:92","text_uthmani":"وَقِيلَ لَهُمْ أَيْنَ مَا كُنتُمْ تَعْبُدُونَ"},{"id":3025,"verse_key":"26:93","text_uthmani":"مِن دُونِ ٱللَّهِ هَلْ يَنصُرُونَكُمْ أَوْ يَنتَصِرُونَ"},{"id":3026,"verse_key":"26:94","text_uthmani":"فَكُبْكِبُوا۟ فِيهَا هُمْ وَٱلْغَاوُۥنَ"},{"id":3027,"verse_key":"26:95","text_uthmani":"وَجُنُودُ إِبْلِيسَ أَجْمَعُونَ"},{"id":3028,"verse_key":"26:96","text_uthmani":"قَالُوا۟ وَهُمْ فِيهَا يَخْتَصِمُونَ"},{"id":3029,"verse_key":"26:97","text_uthmani":"تَٱللَّهِ إِن كُنَّا لَفِى ضَلَـٰلٍ مُّبِينٍ"},{"id":3030,"verse_key":"26:98","text_uthmani":"إِذْ نُسَوِّيكُم بِرَبِّ ٱلْعَـٰلَمِينَ"},{"id":3031,"verse_key":"26:99","text_uthmani":"وَمَآ أَضَلَّنَآ إِلَّا ٱلْمُجْرِمُونَ"},{"id":3032,"verse_key":"26:100","text_uthmani":"فَمَا لَنَا مِن شَـٰفِعِينَ"},{"id":3033,"verse_key":"26:101","text_uthmani":"وَلَا صَدِيقٍ حَمِيمٍ"},{"id":3034,"verse_key":"26:102","text_uthmani":"فَلَوْ أَنَّ لَنَا كَرَّةً فَنَكُونَ مِنَ ٱلْمُؤْمِنِينَ"},{"id":3035,"verse_key":"26:103","text_uthmani":"إِنَّ فِى ذَٰلِكَ لَـَٔايَةً ۖ وَمَا كَانَ أَكْثَرُهُم مُّؤْمِنِينَ"},{"id":3036,"verse_key":"26:104","text_uthmani":"وَإِنَّ رَبَّكَ لَهُوَ ٱلْعَزِيزُ ٱلرَّحِيمُ"},{"id":3037,"verse_key":"26:105","text_uthmani":"كَذَّبَتْ قَوْمُ نُوحٍ ٱلْمُرْسَلِينَ"},{"id":3038,"verse_key":"26:106","text_uthmani":"إِذْ قَالَ لَهُمْ أَخُوهُمْ نُوحٌ أَلَا تَتَّقُونَ"},{"id":3039,"verse_key":"26:107","text_uthmani":"إِنِّى لَكُمْ رَسُولٌ أَمِينٌ"},{"id":3040,"verse_key":"26:108","text_uthmani":"فَٱتَّقُوا۟ ٱللَّهَ وَأَطِيعُونِ"},{"id":3041,"verse_key":"26:109","text_uthmani":"وَمَآ أَسْـَٔلُكُمْ عَلَيْهِ مِنْ أَجْرٍ ۖ إِنْ أَجْرِىَ إِلَّا عَلَىٰ رَبِّ ٱلْعَـٰلَمِينَ"},{"id":3042,"verse_key":"26:110","text_uthmani":"فَٱتَّقُوا۟ ٱللَّهَ وَأَطِيعُونِ"},{"id":3043,"verse_key":"26:111","text_uthmani":"۞ قَالُوٓا۟ أَنُؤْمِنُ لَكَ وَٱتَّبَعَكَ ٱلْأَرْذَلُونَ"}]