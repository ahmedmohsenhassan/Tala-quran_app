[{"id":6177,"verse_key":"103:1","text_uthmani":" وَٱلْعَصْرِ"},{"id":6178,"verse_key":"103:2","text_uthmani":"إِنَّ ٱلْإِنسَـٰنَ لَفِى خُسْرٍ"},{"id":6179,"verse_key":"103:3","text_uthmani":"إِلَّا ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ وَتَوَاصَوْا۟ بِٱلْحَقِّ وَتَوَاصَوْا۟ بِٱلصَّبْرِ"},{"id":6180,"verse_key":"104:1","text_uthmani":" وَيْلٌ لِّكُلِّ هُمَزَةٍ لُّمَزَةٍ"},{"id":6181,"verse_key":"104:2","text_uthmani":"ٱلَّذِى جَمَعَ مَالًا وَعَدَّدَهُۥ"},{"id":6182,"verse_key":"104:3","text_uthmani":"يَحْسَبُ أَنَّ مَالَهُۥٓ أَخْلَدَهُۥ"},{"id":6183,"verse_key":"104:4","text_uthmani":"كَلَّا ۖ لَيُنۢبَذَنَّ فِى ٱلْحُطَمَةِ"},{"id":6184,"verse_key":"104:5","text_uthmani":"وَمَآ أَدْرَىٰكَ مَا ٱلْحُطَمَةُ"},{"id":6185,"verse_key":"104:6","text_uthmani":"نَارُ ٱللَّهِ ٱلْمُوقَدَةُ"},{"id":6186,"verse_key":"104:7","text_uthmani":"ٱلَّتِى تَطَّلِعُ عَلَى ٱلْأَفْـِٔدَةِ"},{"id":6187,"verse_key":"104:8","text_uthmani":"إِنَّهَا عَلَيْهِم مُّؤْصَدَةٌ"},{"id":6188,"verse_key":"104:9","text_uthmani":"فِى عَمَدٍ مُّمَدَّدَةٍۭ"},{"id":6189,"verse_key":"105:1","text_uthmani":" أَلَمْ تَرَ كَيْفَ فَعَلَ رَبُّكَ بِأَصْحَـٰبِ ٱلْفِيلِ"},{"id":6190,"verse_key":"105:2","text_uthmani":"أَلَمْ يَجْعَلْ كَيْدَهُمْ فِى تَضْلِيلٍ"},{"id":6191,"verse_key":"105:3","text_uthmani":"وَأَرْسَلَ عَلَيْهِمْ طَيْرًا أَبَابِيلَ"},{"id":6192,"verse_key":"105:4","text_uthmani":"تَرْمِيهِم بِحِجَارَةٍ مِّن سِجِّيلٍ"},{"id":6193,"verse_key":"105:5","text_uthmani":"فَجَعَلَهُمْ كَعَصْفٍ مَّأْكُولٍۭ"}]