[{"id":4969,"verse_key":"55:68","text_uthmani":"فِيهِمَا فَـٰكِهَةٌ وَنَخْلٌ وَرُمَّانٌ"},{"id":4970,"verse_key":"55:69","text_uthmani":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"id":4971,"verse_key":"55:70","text_uthmani":"فِيهِنَّ خَيْرَٰتٌ حِسَانٌ"},{"id":4972,"verse_key":"55:71","text_uthmani":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"id":4973,"verse_key":"55:72","text_uthmani":"حُورٌ مَّقْصُورَٰتٌ فِى ٱلْخِيَامِ"},{"id":4974,"verse_key":"55:73","text_uthmani":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"id":4975,"verse_key":"55:74","text_uthmani":"لَمْ يَطْمِثْهُنَّ إِنسٌ قَبْلَهُمْ وَلَا جَآنٌّ"},{"id":4976,"verse_key":"55:75","text_uthmani":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"id":4977,"verse_key":"55:76","text_uthmani":"مُتَّكِـِٔينَ عَلَىٰ رَفْرَفٍ خُضْرٍ وَعَبْقَرِىٍّ حِسَانٍ"},{"id":4978,"verse_key":"55:77","text_uthmani":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"id":4979,"verse_key":"55:78","text_uthmani":"تَبَـٰرَكَ ٱسْمُ رَبِّكَ ذِى ٱلْجَلَـٰلِ وَٱلْإِكْرَامِ"},{"id":4980,"verse_key":"56:1","text_uthmani":" إِذَا وَقَعَتِ ٱلْوَاقِعَةُ"},{"id":4981,"verse_key":"56:2","text_uthmani":"لَيْسَ لِوَقْعَتِهَا كَاذِبَةٌ"},{"id":4982,"verse_key":"56:3","text_uthmani":"خَافِضَةٌ رَّافِعَةٌ"},{"id":4983,"verse_key":"56:4","text_uthmani":"إِذَا رُجَّتِ ٱلْأَرْضُ رَجًّا"},{"id":4984,"verse_key":"56:5","text_uthmani":"وَبُسَّتِ ٱلْجِبَالُ بَسًّا"},{"id":4985,"verse_key":"56:6","text_uthmani":"فَكَانَتْ هَبَآءً مُّنۢبَثًّا"},{"id":4986,"verse_key":"56:7","text_uthmani":"وَكُنتُمْ أَزْوَٰجًا ثَلَـٰثَةً"},{"id":4987,"verse_key":"56:8","text_uthmani":"فَأَصْحَـٰبُ ٱلْمَيْمَنَةِ مَآ أَصْحَـٰبُ ٱلْمَيْمَنَةِ"},{"id":4988,"verse_key":"56:9","text_uthmani":"وَأَصْحَـٰبُ ٱلْمَشْـَٔمَةِ مَآ أَصْحَـٰبُ ٱلْمَشْـَٔمَةِ"},{"id":4989,"verse_key":"56:10","text_uthmani":"وَٱلسَّـٰبِقُونَ ٱلسَّـٰبِقُونَ"},{"id":4990,"verse_key":"56:11","text_uthmani":"أُو۟لَـٰٓئِكَ ٱلْمُقَرَّبُونَ"},{"id":4991,"verse_key":"56:12","text_uthmani":"فِى جَنَّـٰتِ ٱلنَّعِيمِ"},{"id":4992,"verse_key":"56:13","text_uthmani":"ثُلَّةٌ مِّنَ ٱلْأَوَّلِينَ"},{"id":4993,"verse_key":"56:14","text_uthmani":"وَقَلِيلٌ مِّنَ ٱلْـَٔاخِرِينَ"},{"id":4994,"verse_key":"56:15","text_uthmani":"عَلَىٰ سُرُرٍ مَّوْضُونَةٍ"},{"id":4995,"verse_key":"56:16","text_uthmani":"مُّتَّكِـِٔينَ عَلَيْهَا مُتَقَـٰبِلِينَ"}]