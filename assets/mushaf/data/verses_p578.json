[{"id":5571,"verse_key":"75:20","text_uthmani":"كَلَّا بَلْ تُحِبُّونَ ٱلْعَاجِلَةَ"},{"id":5572,"verse_key":"75:21","text_uthmani":"وَتَذَرُونَ ٱلْـَٔاخِرَةَ"},{"id":5573,"verse_key":"75:22","text_uthmani":"وُجُوهٌ يَوْمَئِذٍ نَّاضِرَةٌ"},{"id":5574,"verse_key":"75:23","text_uthmani":"إِلَىٰ رَبِّهَا نَاظِرَةٌ"},{"id":5575,"verse_key":"75:24","text_uthmani":"وَوُجُوهٌ يَوْمَئِذٍۭ بَاسِرَةٌ"},{"id":5576,"verse_key":"75:25","text_uthmani":"تَظُنُّ أَن يُفْعَلَ بِهَا فَاقِرَةٌ"},{"id":5577,"verse_key":"75:26","text_uthmani":"كَلَّآ إِذَا بَلَغَتِ ٱلتَّرَاقِىَ"},{"id":5578,"verse_key":"75:27","text_uthmani":"وَقِيلَ مَنْ ۜ رَاقٍ"},{"id":5579,"verse_key":"75:28","text_uthmani":"وَظَنَّ أَنَّهُ ٱلْفِرَاقُ"},{"id":5580,"verse_key":"75:29","text_uthmani":"وَٱلْتَفَّتِ ٱلسَّاقُ بِٱلسَّاقِ"},{"id":5581,"verse_key":"75:30","text_uthmani":"إِلَىٰ رَبِّكَ يَوْمَئِذٍ ٱلْمَسَاقُ"},{"id":5582,"verse_key":"75:31","text_uthmani":"فَلَا صَدَّقَ وَلَا صَلَّىٰ"},{"id":5583,"verse_key":"75:32","text_uthmani":"وَلَـٰكِن كَذَّبَ وَتَوَلَّىٰ"},{"id":5584,"verse_key":"75:33","text_uthmani":"ثُمَّ ذَهَبَ إِلَىٰٓ أَهْلِهِۦ يَتَمَطَّىٰٓ"},{"id":5585,"verse_key":"75:34","text_uthmani":"أَوْلَىٰ لَكَ فَأَوْلَىٰ"},{"id":5586,"verse_key":"75:35","text_uthmani":"ثُمَّ أَوْلَىٰ لَكَ فَأَوْلَىٰٓ"},{"id":5587,"verse_key":"75:36","text_uthmani":"أَيَحْسَبُ ٱلْإِنسَـٰنُ أَن يُتْرَكَ سُدًى"},{"id":5588,"verse_key":"75:37","text_uthmani":"أَلَمْ يَكُ نُطْفَةً مِّن مَّنِىٍّ يُمْنَىٰ"},{"id":5589,"verse_key":"75:38","text_uthmani":"ثُمَّ كَانَ عَلَقَةً فَخَلَقَ فَسَوَّىٰ"},{"id":5590,"verse_key":"75:39","text_uthmani":"فَجَعَلَ مِنْهُ ٱلزَّوْجَيْنِ ٱلذَّكَرَ وَٱلْأُنثَىٰٓ"},{"id":5591,"verse_key":"75:40","text_uthmani":"أَلَيْسَ ذَٰلِكَ بِقَـٰدِرٍ عَلَىٰٓ أَن يُحْـِۧىَ ٱلْمَوْتَىٰ"},{"id":5592,"verse_key":"76:1","text_uthmani":" هَلْ أَتَىٰ عَلَى ٱلْإِنسَـٰنِ حِينٌ مِّنَ ٱلدَّهْرِ لَمْ يَكُن شَيْـًٔا مَّذْكُورًا"},{"id":5593,"verse_key":"76:2","text_uthmani":"إِنَّا خَلَقْنَا ٱلْإِنسَـٰنَ مِن نُّطْفَةٍ أَمْشَاجٍ نَّبْتَلِيهِ فَجَعَلْنَـٰهُ سَمِيعًۢا بَصِيرًا"},{"id":5594,"verse_key":"76:3","text_uthmani":"إِنَّا هَدَيْنَـٰهُ ٱلسَّبِيلَ إِمَّا شَاكِرًا وَإِمَّا كَفُورًا"},{"id":5595,"verse_key":"76:4","text_uthmani":"إِنَّآ أَعْتَدْنَا لِلْكَـٰفِرِينَ سَلَـٰسِلَا۟ وَأَغْلَـٰلًا وَسَعِيرًا"},{"id":5596,"verse_key":"76:5","text_uthmani":"إِنَّ ٱلْأَبْرَارَ يَشْرَبُونَ مِن كَأْسٍ كَانَ مِزَاجُهَا كَافُورًا"}]