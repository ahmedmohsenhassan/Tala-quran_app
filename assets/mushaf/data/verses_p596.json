[{"id":6073,"verse_key":"92:15","text_uthmani":"لَا يَصْلَىٰهَآ إِلَّا ٱلْأَشْقَى"},{"id":6074,"verse_key":"92:16","text_uthmani":"ٱلَّذِى كَذَّبَ وَتَوَلَّىٰ"},{"id":6075,"verse_key":"92:17","text_uthmani":"وَسَيُجَنَّبُهَا ٱلْأَتْقَى"},{"id":6076,"verse_key":"92:18","text_uthmani":"ٱلَّذِى يُؤْتِى مَالَهُۥ يَتَزَكَّىٰ"},{"id":6077,"verse_key":"92:19","text_uthmani":"وَمَا لِأَحَدٍ عِندَهُۥ مِن نِّعْمَةٍ تُجْزَىٰٓ"},{"id":6078,"verse_key":"92:20","text_uthmani":"إِلَّا ٱبْتِغَآءَ وَجْهِ رَبِّهِ ٱلْأَعْلَىٰ"},{"id":6079,"verse_key":"92:21","text_uthmani":"وَلَسَوْفَ يَرْضَىٰ"},{"id":6080,"verse_key":"93:1","text_uthmani":" وَٱلضُّحَىٰ"},{"id":6081,"verse_key":"93:2","text_uthmani":"وَٱلَّيْلِ إِذَا سَجَىٰ"},{"id":6082,"verse_key":"93:3","text_uthmani":"مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَىٰ"},{"id":6083,"verse_key":"93:4","text_uthmani":"وَلَلْـَٔاخِرَةُ خَيْرٌ لَّكَ مِنَ ٱلْأُولَىٰ"},{"id":6084,"verse_key":"93:5","text_uthmani":"وَلَسَوْفَ يُعْطِيكَ رَبُّكَ فَتَرْضَىٰٓ"},{"id":6085,"verse_key":"93:6","text_uthmani":"أَلَمْ يَجِدْكَ يَتِيمًا فَـَٔاوَىٰ"},{"id":6086,"verse_key":"93:7","text_uthmani":"وَوَجَدَكَ ضَآلًّا فَهَدَىٰ"},{"id":6087,"verse_key":"93:8","text_uthmani":"وَوَجَدَكَ عَآئِلًا فَأَغْنَىٰ"},{"id":6088,"verse_key":"93:9","text_uthmani":"فَأَمَّا ٱلْيَتِيمَ فَلَا تَقْهَرْ"},{"id":6089,"verse_key":"93:10","text_uthmani":"وَأَمَّا ٱلسَّآئِلَ فَلَا تَنْهَرْ"},{"id":6090,"verse_key":"93:11","text_uthmani":"وَأَمَّا بِنِعْمَةِ رَبِّكَ فَحَدِّثْ"},{"id":6091,"verse_key":"94:1","text_uthmani":" أَلَمْ نَشْرَحْ لَكَ صَدْرَكَ"},{"id":6092,"verse_key":"94:2","text_uthmani":"وَوَضَعْنَا عَنكَ وِزْرَكَ"},{"id":6093,"verse_key":"94:3","text_uthmani":"ٱلَّذِىٓ أَنقَضَ ظَهْرَكَ"},{"id":6094,"verse_key":"94:4","text_uthmani":"وَرَفَعْنَا لَكَ ذِكْرَكَ"},{"id":6095,"verse_key":"94:5","text_uthmani":"فَإِنَّ مَعَ ٱلْعُسْرِ يُسْرًا"},{"id":6096,"verse_key":"94:6","text_uthmani":"إِنَّ مَعَ ٱلْعُسْرِ يُسْرًا"},{"id":6097,"verse_key":"94:7","text_uthmani":"فَإِذَا فَرَغْتَ فَٱنصَبْ"},{"id":6098,"verse_key":"94:8","text_uthmani":"وَإِلَىٰ رَبِّكَ فَٱرْغَب"}]