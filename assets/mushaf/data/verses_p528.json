[{"id":4829,"verse_key":"53:45","text_uthmani":"وَأَنَّهُۥ خَلَقَ ٱلزَّوْجَيْنِ ٱلذَّكَرَ وَٱلْأُنثَىٰ"},{"id":4830,"verse_key":"53:46","text_uthmani":"مِن نُّطْفَةٍ إِذَا تُمْنَىٰ"},{"id":4831,"verse_key":"53:47","text_uthmani":"وَأَنَّ عَلَيْهِ ٱلنَّشْأَةَ ٱلْأُخْرَىٰ"},{"id":4832,"verse_key":"53:48","text_uthmani":"وَأَنَّهُۥ هُوَ أَغْنَىٰ وَأَقْنَىٰ"},{"id":4833,"verse_key":"53:49","text_uthmani":"وَأَنَّهُۥ هُوَ رَبُّ ٱلشِّعْرَىٰ"},{"id":4834,"verse_key":"53:50","text_uthmani":"وَأَنَّهُۥٓ أَهْلَكَ عَادًا ٱلْأُولَىٰ"},{"id":4835,"verse_key":"53:51","text_uthmani":"وَثَمُودَا۟ فَمَآ أَبْقَىٰ"},{"id":4836,"verse_key":"53:52","text_uthmani":"وَقَوْمَ نُوحٍ مِّن قَبْلُ ۖ إِنَّهُمْ كَانُوا۟ هُمْ أَظْلَمَ وَأَطْغَىٰ"},{"id":4837,"verse_key":"53:53","text_uthmani":"وَٱلْمُؤْتَفِكَةَ أَهْوَىٰ"},{"id":4838,"verse_key":"53:54","text_uthmani":"فَغَشَّىٰهَا مَا غَشَّىٰ"},{"id":4839,"verse_key":"53:55","text_uthmani":"فَبِأَىِّ ءَالَآءِ رَبِّكَ تَتَمَارَىٰ"},{"id":4840,"verse_key":"53:56","text_uthmani":"هَـٰذَا نَذِيرٌ مِّنَ ٱلنُّذُرِ ٱلْأُولَىٰٓ"},{"id":4841,"verse_key":"53:57","text_uthmani":"أَزِفَتِ ٱلْـَٔازِفَةُ"},{"id":4842,"verse_key":"53:58","text_uthmani":"لَيْسَ لَهَا مِن دُونِ ٱللَّهِ كَاشِفَةٌ"},{"id":4843,"verse_key":"53:59","text_uthmani":"أَفَمِنْ هَـٰذَا ٱلْحَدِيثِ تَعْجَبُونَ"},{"id":4844,"verse_key":"53:60","text_uthmani":"وَتَضْحَكُونَ وَلَا تَبْكُونَ"},{"id":4845,"verse_key":"53:61","text_uthmani":"وَأَنتُمْ سَـٰمِدُونَ"},{"id":4846,"verse_key":"53:62","text_uthmani":"فَٱسْجُدُوا۟ لِلَّهِ وَٱعْبُدُوا۟ ۩"},{"id":4847,"verse_key":"54:1","text_uthmani":" ٱقْتَرَبَتِ ٱلسَّاعَةُ وَٱنشَقَّ ٱلْقَمَرُ"},{"id":4848,"verse_key":"54:2","text_uthmani":"وَإِن يَرَوْا۟ ءَايَةً يُعْرِضُوا۟ وَيَقُولُوا۟ سِحْرٌ مُّسْتَمِرٌّ"},{"id":4849,"verse_key":"54:3","text_uthmani":"وَكَذَّبُوا۟ وَٱتَّبَعُوٓا۟ أَهْوَآءَهُمْ ۚ وَكُلُّ أَمْرٍ مُّسْتَقِرٌّ"},{"id":4850,"verse_key":"54:4","text_uthmani":"وَلَقَدْ جَآءَهُم مِّنَ ٱلْأَنۢبَآءِ مَا فِيهِ مُزْدَجَرٌ"},{"id":4851,"verse_key":"54:5","text_uthmani":"حِكْمَةٌۢ بَـٰلِغَةٌ ۖ فَمَا تُغْنِ ٱلنُّذُرُ"},{"id":4852,"verse_key":"54:6","text_uthmani":"فَتَوَلَّ عَنْهُمْ ۘ يَوْمَ يَدْعُ ٱلدَّاعِ إِلَىٰ شَىْءٍ نُّكُرٍ"}]