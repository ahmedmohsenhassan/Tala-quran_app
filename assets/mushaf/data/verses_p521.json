[{"id":4682,"verse_key":"51:7","text_uthmani":"وَٱلسَّمَآءِ ذَاتِ ٱلْحُبُكِ"},{"id":4683,"verse_key":"51:8","text_uthmani":"إِنَّكُمْ لَفِى قَوْلٍ مُّخْتَلِفٍ"},{"id":4684,"verse_key":"51:9","text_uthmani":"يُؤْفَكُ عَنْهُ مَنْ أُفِكَ"},{"id":4685,"verse_key":"51:10","text_uthmani":"قُتِلَ ٱلْخَرَّٰصُونَ"},{"id":4686,"verse_key":"51:11","text_uthmani":"ٱلَّذِينَ هُمْ فِى غَمْرَةٍ سَاهُونَ"},{"id":4687,"verse_key":"51:12","text_uthmani":"يَسْـَٔلُونَ أَيَّانَ يَوْمُ ٱلدِّينِ"},{"id":4688,"verse_key":"51:13","text_uthmani":"يَوْمَ هُمْ عَلَى ٱلنَّارِ يُفْتَنُونَ"},{"id":4689,"verse_key":"51:14","text_uthmani":"ذُوقُوا۟ فِتْنَتَكُمْ هَـٰذَا ٱلَّذِى كُنتُم بِهِۦ تَسْتَعْجِلُونَ"},{"id":4690,"verse_key":"51:15","text_uthmani":"إِنَّ ٱلْمُتَّقِينَ فِى جَنَّـٰتٍ وَعُيُونٍ"},{"id":4691,"verse_key":"51:16","text_uthmani":"ءَاخِذِينَ مَآ ءَاتَىٰهُمْ رَبُّهُمْ ۚ إِنَّهُمْ كَانُوا۟ قَبْلَ ذَٰلِكَ مُحْسِنِينَ"},{"id":4692,"verse_key":"51:17","text_uthmani":"كَانُوا۟ قَلِيلًا مِّنَ ٱلَّيْلِ مَا يَهْجَعُونَ"},{"id":4693,"verse_key":"51:18","text_uthmani":"وَبِٱلْأَسْحَارِ هُمْ يَسْتَغْفِرُونَ"},{"id":4694,"verse_key":"51:19","text_uthmani":"وَفِىٓ أَمْوَٰلِهِمْ حَقٌّ لِّلسَّآئِلِ وَٱلْمَحْرُومِ"},{"id":4695,"verse_key":"51:20","text_uthmani":"وَفِى ٱلْأَرْضِ ءَايَـٰتٌ لِّلْمُوقِنِينَ"},{"id":4696,"verse_key":"51:21","text_uthmani":"وَفِىٓ أَنفُسِكُمْ ۚ أَفَلَا تُبْصِرُونَ"},{"id":4697,"verse_key":"51:22","text_uthmani":"وَفِى ٱلسَّمَآءِ رِزْقُكُمْ وَمَا تُوعَدُونَ"},{"id":4698,"verse_key":"51:23","text_uthmani":"فَوَرَبِّ ٱلسَّمَآءِ وَٱلْأَرْضِ إِنَّهُۥ لَحَقٌّ مِّثْلَ مَآ أَنَّكُمْ تَنطِقُونَ"},{"id":4699,"verse_key":"51:24","text_uthmani":"هَلْ أَتَىٰكَ حَدِيثُ ضَيْفِ إِبْرَٰهِيمَ ٱلْمُكْرَمِينَ"},{"id":4700,"verse_key":"51:25","text_uthmani":"إِذْ دَخَلُوا۟ عَلَيْهِ فَقَالُوا۟ سَلَـٰمًا ۖ قَالَ سَلَـٰمٌ قَوْمٌ مُّنكَرُونَ"},{"id":4701,"verse_key":"51:26","text_uthmani":"فَرَاغَ إِلَىٰٓ أَهْلِهِۦ فَجَآءَ بِعِجْلٍ سَمِينٍ"},{"id":4702,"verse_key":"51:27","text_uthmani":"فَقَرَّبَهُۥٓ إِلَيْهِمْ قَالَ أَلَا تَأْكُلُونَ"},{"id":4703,"verse_key":"51:28","text_uthmani":"فَأَوْجَسَ مِنْهُمْ خِيفَةً ۖ قَالُوا۟ لَا تَخَفْ ۖ وَبَشَّرُوهُ بِغُلَـٰمٍ عَلِيمٍ"},{"id":4704,"verse_key":"51:29","text_uthmani":"فَأَقْبَلَتِ ٱمْرَأَتُهُۥ فِى صَرَّةٍ فَصَكَّتْ وَجْهَهَا وَقَالَتْ عَجُوزٌ عَقِيمٌ"},{"id":4705,"verse_key":"51:30","text_uthmani":"قَالُوا۟ كَذَٰلِكِ قَالَ رَبُّكِ ۖ إِنَّهُۥ هُوَ ٱلْحَكِيمُ ٱلْعَلِيمُ"}]