[{"id":5932,"verse_key":"86:1","text_uthmani":" وَٱلسَّمَآءِ وَٱلطَّارِقِ"},{"id":5933,"verse_key":"86:2","text_uthmani":"وَمَآ أَدْرَىٰكَ مَا ٱلطَّارِقُ"},{"id":5934,"verse_key":"86:3","text_uthmani":"ٱلنَّجْمُ ٱلثَّاقِبُ"},{"id":5935,"verse_key":"86:4","text_uthmani":"إِن كُلُّ نَفْسٍ لَّمَّا عَلَيْهَا حَافِظٌ"},{"id":5936,"verse_key":"86:5","text_uthmani":"فَلْيَنظُرِ ٱلْإِنسَـٰنُ مِمَّ خُلِقَ"},{"id":5937,"verse_key":"86:6","text_uthmani":"خُلِقَ مِن مَّآءٍ دَافِقٍ"},{"id":5938,"verse_key":"86:7","text_uthmani":"يَخْرُجُ مِنۢ بَيْنِ ٱلصُّلْبِ وَٱلتَّرَآئِبِ"},{"id":5939,"verse_key":"86:8","text_uthmani":"إِنَّهُۥ عَلَىٰ رَجْعِهِۦ لَقَادِرٌ"},{"id":5940,"verse_key":"86:9","text_uthmani":"يَوْمَ تُبْلَى ٱلسَّرَآئِرُ"},{"id":5941,"verse_key":"86:10","text_uthmani":"فَمَا لَهُۥ مِن قُوَّةٍ وَلَا نَاصِرٍ"},{"id":5942,"verse_key":"86:11","text_uthmani":"وَٱلسَّمَآءِ ذَاتِ ٱلرَّجْعِ"},{"id":5943,"verse_key":"86:12","text_uthmani":"وَٱلْأَرْضِ ذَاتِ ٱلصَّدْعِ"},{"id":5944,"verse_key":"86:13","text_uthmani":"إِنَّهُۥ لَقَوْلٌ فَصْلٌ"},{"id":5945,"verse_key":"86:14","text_uthmani":"وَمَا هُوَ بِٱلْهَزْلِ"},{"id":5946,"verse_key":"86:15","text_uthmani":"إِنَّهُمْ يَكِيدُونَ كَيْدًا"},{"id":5947,"verse_key":"86:16","text_uthmani":"وَأَكِيدُ كَيْدًا"},{"id":5948,"verse_key":"86:17","text_uthmani":"فَمَهِّلِ ٱلْكَـٰفِرِينَ أَمْهِلْهُمْ رُوَيْدًۢا"},{"id":5949,"verse_key":"87:1","text_uthmani":" سَبِّحِ ٱسْمَ رَبِّكَ ٱلْأَعْلَى"},{"id":5950,"verse_key":"87:2","text_uthmani":"ٱلَّذِى خَلَقَ فَسَوَّىٰ"},{"id":5951,"verse_key":"87:3","text_uthmani":"وَٱلَّذِى قَدَّرَ فَهَدَىٰ"},{"id":5952,"verse_key":"87:4","text_uthmani":"وَٱلَّذِىٓ أَخْرَجَ ٱلْمَرْعَىٰ"},{"id":5953,"verse_key":"87:5","text_uthmani":"فَجَعَلَهُۥ غُثَآءً أَحْوَىٰ"},{"id":5954,"verse_key":"87:6","text_uthmani":"سَنُقْرِئُكَ فَلَا تَنسَىٰٓ"},{"id":5955,"verse_key":"87:7","text_uthmani":"إِلَّا مَا شَآءَ ٱللَّهُ ۚ إِنَّهُۥ يَعْلَمُ ٱلْجَهْرَ وَمَا يَخْفَىٰ"},{"id":5956,"verse_key":"87:8","text_uthmani":"وَنُيَسِّرُكَ لِلْيُسْرَىٰ"},{"id":5957,"verse_key":"87:9","text_uthmani":"فَذَكِّرْ إِن نَّفَعَتِ ٱلذِّكْرَىٰ"},{"id":5958,"verse_key":"87:10","text_uthmani":"سَيَذَّكَّرُ مَن يَخْشَىٰ"},{"id":5959,"verse_key":"87:11","text_uthmani":"وَيَتَجَنَّبُهَا ٱلْأَشْقَى"},{"id":5960,"verse_key":"87:12","text_uthmani":"ٱلَّذِى يَصْلَى ٱلنَّارَ ٱلْكُبْرَىٰ"},{"id":5961,"verse_key":"87:13","text_uthmani":"ثُمَّ لَا يَمُوتُ فِيهَا وَلَا يَحْيَىٰ"},{"id":5962,"verse_key":"87:14","text_uthmani":"قَدْ أَفْلَحَ مَن تَزَكَّىٰ"},{"id":5963,"verse_key":"87:15","text_uthmani":"وَذَكَرَ ٱسْمَ رَبِّهِۦ فَصَلَّىٰ"}]