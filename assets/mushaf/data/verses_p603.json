[{"id":6208,"verse_key":"109:1","text_uthmani":" قُلْ يَـٰٓأَيُّهَا ٱلْكَـٰفِرُونَ"},{"id":6209,"verse_key":"109:2","text_uthmani":"لَآ أَعْبُدُ مَا تَعْبُدُونَ"},{"id":6210,"verse_key":"109:3","text_uthmani":"وَلَآ أَنتُمْ عَـٰبِدُونَ مَآ أَعْبُدُ"},{"id":6211,"verse_key":"109:4","text_uthmani":"وَلَآ أَنَا۠ عَابِدٌ مَّا عَبَدتُّمْ"},{"id":6212,"verse_key":"109:5","text_uthmani":"وَلَآ أَنتُمْ عَـٰبِدُونَ مَآ أَعْبُدُ"},{"id":6213,"verse_key":"109:6","text_uthmani":"لَكُمْ دِينُكُمْ وَلِىَ دِينِ"},{"id":6214,"verse_key":"110:1","text_uthmani":" إِذَا جَآءَ نَصْرُ ٱللَّهِ وَٱلْفَتْحُ"},{"id":6215,"verse_key":"110:2","text_uthmani":"وَرَأَيْتَ ٱلنَّاسَ يَدْخُلُونَ فِى دِينِ ٱللَّهِ أَفْوَاجًا"},{"id":6216,"verse_key":"110:3","text_uthmani":"فَسَبِّحْ بِحَمْدِ رَبِّكَ وَٱسْتَغْفِرْهُ ۚ إِنَّهُۥ كَانَ تَوَّابًۢا"},{"id":6217,"verse_key":"111:1","text_uthmani":" تَبَّتْ يَدَآ أَبِى لَهَبٍ وَتَبَّ"},{"id":6218,"verse_key":"111:2","text_uthmani":"مَآ أَغْنَىٰ عَنْهُ مَالُهُۥ وَمَا كَسَبَ"},{"id":6219,"verse_key":"111:3","text_uthmani":"سَيَصْلَىٰ نَارًا ذَاتَ لَهَبٍ"},{"id":6220,"verse_key":"111:4","text_uthmani":"وَٱمْرَأَتُهُۥ حَمَّالَةَ ٱلْحَطَبِ"},{"id":6221,"verse_key":"111:5","text_uthmani":"فِى جِيدِهَا حَبْلٌ مِّن مَّسَدٍۭ"}]