[{"id":4727,"verse_key":"51:52","text_uthmani":"كَذَٰلِكَ مَآ أَتَى ٱلَّذِينَ مِن قَبْلِهِم مِّن رَّسُولٍ إِلَّا قَالُوا۟ سَاحِرٌ أَوْ مَجْنُونٌ"},{"id":4728,"verse_key":"51:53","text_uthmani":"أَتَوَاصَوْا۟ بِهِۦ ۚ بَلْ هُمْ قَوْمٌ طَاغُونَ"},{"id":4729,"verse_key":"51:54","text_uthmani":"فَتَوَلَّ عَنْهُمْ فَمَآ أَنتَ بِمَلُومٍ"},{"id":4730,"verse_key":"51:55","text_uthmani":"وَذَكِّرْ فَإِنَّ ٱلذِّكْرَىٰ تَنفَعُ ٱلْمُؤْمِنِينَ"},{"id":4731,"verse_key":"51:56","text_uthmani":"وَمَا خَلَقْتُ ٱلْجِنَّ وَٱلْإِنسَ إِلَّا لِيَعْبُدُونِ"},{"id":4732,"verse_key":"51:57","text_uthmani":"مَآ أُرِيدُ مِنْهُم مِّن رِّزْقٍ وَمَآ أُرِيدُ أَن يُطْعِمُونِ"},{"id":4733,"verse_key":"51:58","text_uthmani":"إِنَّ ٱللَّهَ هُوَ ٱلرَّزَّاقُ ذُو ٱلْقُوَّةِ ٱلْمَتِينُ"},{"id":4734,"verse_key":"51:59","text_uthmani":"فَإِنَّ لِلَّذِينَ ظَلَمُوا۟ ذَنُوبًا مِّثْلَ ذَنُوبِ أَصْحَـٰبِهِمْ فَلَا يَسْتَعْجِلُونِ"},{"id":4735,"verse_key":"51:60","text_uthmani":"فَوَيْلٌ لِّلَّذِينَ كَفَرُوا۟ مِن يَوْمِهِمُ ٱلَّذِى يُوعَدُونَ"},{"id":4736,"verse_key":"52:1","text_uthmani":" وَٱلطُّورِ"},{"id":4737,"verse_key":"52:2","text_uthmani":"وَكِتَـٰبٍ مَّسْطُورٍ"},{"id":4738,"verse_key":"52:3","text_uthmani":"فِى رَقٍّ مَّنشُورٍ"},{"id":4739,"verse_key":"52:4","text_uthmani":"وَٱلْبَيْتِ ٱلْمَعْمُورِ"},{"id":4740,"verse_key":"52:5","text_uthmani":"وَٱلسَّقْفِ ٱلْمَرْفُوعِ"},{"id":4741,"verse_key":"52:6","text_uthmani":"وَٱلْبَحْرِ ٱلْمَسْجُورِ"},{"id":4742,"verse_key":"52:7","text_uthmani":"إِنَّ عَذَابَ رَبِّكَ لَوَٰقِعٌ"},{"id":4743,"verse_key":"52:8","text_uthmani":"مَّا لَهُۥ مِن دَافِعٍ"},{"id":4744,"verse_key":"52:9","text_uthmani":"يَوْمَ تَمُورُ ٱلسَّمَآءُ مَوْرًا"},{"id":4745,"verse_key":"52:10","text_uthmani":"وَتَسِيرُ ٱلْجِبَالُ سَيْرًا"},{"id":4746,"verse_key":"52:11","text_uthmani":"فَوَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ"},{"id":4747,"verse_key":"52:12","text_uthmani":"ٱلَّذِينَ هُمْ فِى خَوْضٍ يَلْعَبُونَ"},{"id":4748,"verse_key":"52:13","text_uthmani":"يَوْمَ يُدَعُّونَ إِلَىٰ نَارِ جَهَنَّمَ دَعًّا"},{"id":4749,"verse_key":"52:14","text_uthmani":"هَـٰذِهِ ٱلنَّارُ ٱلَّتِى كُنتُم بِهَا تُكَذِّبُونَ"}]