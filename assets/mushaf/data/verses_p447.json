[{"id":3813,"verse_key":"37:25","text_uthmani":"مَا لَكُمْ لَا تَنَاصَرُونَ"},{"id":3814,"verse_key":"37:26","text_uthmani":"بَلْ هُمُ ٱلْيَوْمَ مُسْتَسْلِمُونَ"},{"id":3815,"verse_key":"37:27","text_uthmani":"وَأَقْبَلَ بَعْضُهُمْ عَلَىٰ بَعْضٍ يَتَسَآءَلُونَ"},{"id":3816,"verse_key":"37:28","text_uthmani":"قَالُوٓا۟ إِنَّكُمْ كُنتُمْ تَأْتُونَنَا عَنِ ٱلْيَمِينِ"},{"id":3817,"verse_key":"37:29","text_uthmani":"قَالُوا۟ بَل لَّمْ تَكُونُوا۟ مُؤْمِنِينَ"},{"id":3818,"verse_key":"37:30","text_uthmani":"وَمَا كَانَ لَنَا عَلَيْكُم مِّن سُلْطَـٰنٍۭ ۖ بَلْ كُنتُمْ قَوْمًا طَـٰغِينَ"},{"id":3819,"verse_key":"37:31","text_uthmani":"فَحَقَّ عَلَيْنَا قَوْلُ رَبِّنَآ ۖ إِنَّا لَذَآئِقُونَ"},{"id":3820,"verse_key":"37:32","text_uthmani":"فَأَغْوَيْنَـٰكُمْ إِنَّا كُنَّا غَـٰوِينَ"},{"id":3821,"verse_key":"37:33","text_uthmani":"فَإِنَّهُمْ يَوْمَئِذٍ فِى ٱلْعَذَابِ مُشْتَرِكُونَ"},{"id":3822,"verse_key":"37:34","text_uthmani":"إِنَّا كَذَٰلِكَ نَفْعَلُ بِٱلْمُجْرِمِينَ"},{"id":3823,"verse_key":"37:35","text_uthmani":"إِنَّهُمْ كَانُوٓا۟ إِذَا قِيلَ لَهُمْ لَآ إِلَـٰهَ إِلَّا ٱللَّهُ يَسْتَكْبِرُونَ"},{"id":3824,"verse_key":"37:36","text_uthmani":"وَيَقُولُونَ أَئِنَّا لَتَارِكُوٓا۟ ءَالِهَتِنَا لِشَاعِرٍ مَّجْنُونٍۭ"},{"id":3825,"verse_key":"37:37","text_uthmani":"بَلْ جَآءَ بِٱلْحَقِّ وَصَدَّقَ ٱلْمُرْسَلِينَ"},{"id":3826,"verse_key":"37:38","text_uthmani":"إِنَّكُمْ لَذَآئِقُوا۟ ٱلْعَذَابِ ٱلْأَلِيمِ"},{"id":3827,"verse_key":"37:39","text_uthmani":"وَمَا تُجْزَوْنَ إِلَّا مَا كُنتُمْ تَعْمَلُونَ"},{"id":3828,"verse_key":"37:40","text_uthmani":"إِلَّا عِبَادَ ٱللَّهِ ٱلْمُخْلَصِينَ"},{"id":3829,"verse_key":"37:41","text_uthmani":"أُو۟لَـٰٓئِكَ لَهُمْ رِزْقٌ مَّعْلُومٌ"},{"id":3830,"verse_key":"37:42","text_uthmani":"فَوَٰكِهُ ۖ وَهُم مُّكْرَمُونَ"},{"id":3831,"verse_key":"37:43","text_uthmani":"فِى جَنَّـٰتِ ٱلنَّعِيمِ"},{"id":3832,"verse_key":"37:44","text_uthmani":"عَلَىٰ سُرُرٍ مُّتَقَـٰبِلِينَ"},{"id":3833,"verse_key":"37:45","text_uthmani":"يُطَافُ عَلَيْهِم بِكَأْسٍ مِّن مَّعِينٍۭ"},{"id":3834,"verse_key":"37:46","text_uthmani":"بَيْضَآءَ لَذَّةٍ لِّلشَّـٰرِبِينَ"},{"id":3835,"verse_key":"37:47","text_uthmani":"لَا فِيهَا غَوْلٌ وَلَا هُمْ عَنْهَا يُنزَفُونَ"},{"id":3836,"verse_key":"37:48","text_uthmani":"وَعِندَهُمْ قَـٰصِرَٰتُ ٱلطَّرْفِ عِينٌ"},{"id":3837,"verse_key":"37:49","text_uthmani":"كَأَنَّهُنَّ بَيْضٌ مَّكْنُونٌ"},{"id":3838,"verse_key":"37:50","text_uthmani":"فَأَقْبَلَ بَعْضُهُمْ عَلَىٰ بَعْضٍ يَتَسَآءَلُونَ"},{"id":3839,"verse_key":"37:51","text_uthmani":"قَالَ قَآئِلٌ مِّنْهُمْ إِنِّى كَانَ لِى قَرِينٌ"}]