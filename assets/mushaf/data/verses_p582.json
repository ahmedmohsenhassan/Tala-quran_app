[{"id":5673,"verse_key":"78:1","text_uthmani":" عَمَّ يَتَسَآءَلُونَ"},{"id":5674,"verse_key":"78:2","text_uthmani":"عَنِ ٱلنَّبَإِ ٱلْعَظِيمِ"},{"id":5675,"verse_key":"78:3","text_uthmani":"ٱلَّذِى هُمْ فِيهِ مُخْتَلِفُونَ"},{"id":5676,"verse_key":"78:4","text_uthmani":"كَلَّا سَيَعْلَمُونَ"},{"id":5677,"verse_key":"78:5","text_uthmani":"ثُمَّ كَلَّا سَيَعْلَمُونَ"},{"id":5678,"verse_key":"78:6","text_uthmani":"أَلَمْ نَجْعَلِ ٱلْأَرْضَ مِهَـٰدًا"},{"id":5679,"verse_key":"78:7","text_uthmani":"وَٱلْجِبَالَ أَوْتَادًا"},{"id":5680,"verse_key":"78:8","text_uthmani":"وَخَلَقْنَـٰكُمْ أَزْوَٰجًا"},{"id":5681,"verse_key":"78:9","text_uthmani":"وَجَعَلْنَا نَوْمَكُمْ سُبَاتًا"},{"id":5682,"verse_key":"78:10","text_uthmani":"وَجَعَلْنَا ٱلَّيْلَ لِبَاسًا"},{"id":5683,"verse_key":"78:11","text_uthmani":"وَجَعَلْنَا ٱلنَّهَارَ مَعَاشًا"},{"id":5684,"verse_key":"78:12","text_uthmani":"وَبَنَيْنَا فَوْقَكُمْ سَبْعًا شِدَادًا"},{"id":5685,"verse_key":"78:13","text_uthmani":"وَجَعَلْنَا سِرَاجًا وَهَّاجًا"},{"id":5686,"verse_key":"78:14","text_uthmani":"وَأَنزَلْنَا مِنَ ٱلْمُعْصِرَٰتِ مَآءً ثَجَّاجًا"},{"id":5687,"verse_key":"78:15","text_uthmani":"لِّنُخْرِجَ بِهِۦ حَبًّا وَنَبَاتًا"},{"id":5688,"verse_key":"78:16","text_uthmani":"وَجَنَّـٰتٍ أَلْفَافًا"},{"id":5689,"verse_key":"78:17","text_uthmani":"إِنَّ يَوْمَ ٱلْفَصْلِ كَانَ مِيقَـٰتًا"},{"id":5690,"verse_key":"78:18","text_uthmani":"يَوْمَ يُنفَخُ فِى ٱلصُّورِ فَتَأْتُونَ أَفْوَاجًا"},{"id":5691,"verse_key":"78:19","text_uthmani":"وَفُتِحَتِ ٱلسَّمَآءُ فَكَانَتْ أَبْوَٰبًا"},{"id":5692,"verse_key":"78:20","text_uthmani":"وَسُيِّرَتِ ٱلْجِبَالُ فَكَانَتْ سَرَابًا"},{"id":5693,"verse_key":"78:21","text_uthmani":"إِنَّ جَهَنَّمَ كَانَتْ مِرْصَادًا"},{"id":5694,"verse_key":"78:22","text_uthmani":"لِّلطَّـٰغِينَ مَـَٔابًا"},{"id":5695,"verse_key":"78:23","text_uthmani":"لَّـٰبِثِينَ فِيهَآ أَحْقَابًا"},{"id":5696,"verse_key":"78:24","text_uthmani":"لَّا يَذُوقُونَ فِيهَا بَرْدًا وَلَا شَرَابًا"},{"id":5697,"verse_key":"78:25","text_uthmani":"إِلَّا حَمِيمًا وَغَسَّاقًا"},{"id":5698,"verse_key":"78:26","text_uthmani":"جَزَآءً وِفَاقًا"},{"id":5699,"verse_key":"78:27","text_uthmani":"إِنَّهُمْ كَانُوا۟ لَا يَرْجُونَ حِسَابًا"},{"id":5700,"verse_key":"78:28","text_uthmani":"وَكَذَّبُوا۟ بِـَٔايَـٰتِنَا كِذَّابًا"},{"id":5701,"verse_key":"78:29","text_uthmani":"وَكُلَّ شَىْءٍ أَحْصَيْنَـٰهُ كِتَـٰبًا"},{"id":5702,"verse_key":"78:30","text_uthmani":"فَذُوقُوا۟ فَلَن نَّزِيدَكُمْ إِلَّا عَذَابًا"}]