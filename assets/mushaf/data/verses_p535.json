[{"id":4996,"verse_key":"56:17","text_uthmani":"يَطُوفُ عَلَيْهِمْ وِلْدَٰنٌ مُّخَلَّدُونَ"},{"id":4997,"verse_key":"56:18","text_uthmani":"بِأَكْوَابٍ وَأَبَارِيقَ وَكَأْسٍ مِّن مَّعِينٍ"},{"id":4998,"verse_key":"56:19","text_uthmani":"لَّا يُصَدَّعُونَ عَنْهَا وَلَا يُنزِفُونَ"},{"id":4999,"verse_key":"56:20","text_uthmani":"وَفَـٰكِهَةٍ مِّمَّا يَتَخَيَّرُونَ"},{"id":5000,"verse_key":"56:21","text_uthmani":"وَلَحْمِ طَيْرٍ مِّمَّا يَشْتَهُونَ"},{"id":5001,"verse_key":"56:22","text_uthmani":"وَحُورٌ عِينٌ"},{"id":5002,"verse_key":"56:23","text_uthmani":"كَأَمْثَـٰلِ ٱللُّؤْلُؤِ ٱلْمَكْنُونِ"},{"id":5003,"verse_key":"56:24","text_uthmani":"جَزَآءًۢ بِمَا كَانُوا۟ يَعْمَلُونَ"},{"id":5004,"verse_key":"56:25","text_uthmani":"لَا يَسْمَعُونَ فِيهَا لَغْوًا وَلَا تَأْثِيمًا"},{"id":5005,"verse_key":"56:26","text_uthmani":"إِلَّا قِيلًا سَلَـٰمًا سَلَـٰمًا"},{"id":5006,"verse_key":"56:27","text_uthmani":"وَأَصْحَـٰبُ ٱلْيَمِينِ مَآ أَصْحَـٰبُ ٱلْيَمِينِ"},{"id":5007,"verse_key":"56:28","text_uthmani":"فِى سِدْرٍ مَّخْضُودٍ"},{"id":5008,"verse_key":"56:29","text_uthmani":"وَطَلْحٍ مَّنضُودٍ"},{"id":5009,"verse_key":"56:30","text_uthmani":"وَظِلٍّ مَّمْدُودٍ"},{"id":5010,"verse_key":"56:31","text_uthmani":"وَمَآءٍ مَّسْكُوبٍ"},{"id":5011,"verse_key":"56:32","text_uthmani":"وَفَـٰكِهَةٍ كَثِيرَةٍ"},{"id":5012,"verse_key":"56:33","text_uthmani":"لَّا مَقْطُوعَةٍ وَلَا مَمْنُوعَةٍ"},{"id":5013,"verse_key":"56:34","text_uthmani":"وَفُرُشٍ مَّرْفُوعَةٍ"},{"id":5014,"verse_key":"56:35","text_uthmani":"إِنَّآ أَنشَأْنَـٰهُنَّ إِنشَآءً"},{"id":5015,"verse_key":"56:36","text_uthmani":"فَجَعَلْنَـٰهُنَّ أَبْكَارًا"},{"id":5016,"verse_key":"56:37","text_uthmani":"عُرُبًا أَتْرَابًا"},{"id":5017,"verse_key":"56:38","text_uthmani":"لِّأَصْحَـٰبِ ٱلْيَمِينِ"},{"id":5018,"verse_key":"56:39","text_uthmani":"ثُلَّةٌ مِّنَ ٱلْأَوَّلِينَ"},{"id":5019,"verse_key":"56:40","text_uthmani":"وَثُلَّةٌ مِّنَ ٱلْـَٔاخِرِينَ"},{"id":5020,"verse_key":"56:41","text_uthmani":"وَأَصْحَـٰبُ ٱلشِّمَالِ مَآ أَصْحَـٰبُ ٱلشِّمَالِ"},{"id":5021,"verse_key":"56:42","text_uthmani":"فِى سَمُومٍ وَحَمِيمٍ"},{"id":5022,"verse_key":"56:43","text_uthmani":"وَظِلٍّ مِّن يَحْمُومٍ"},{"id":5023,"verse_key":"56:44","text_uthmani":"لَّا بَارِدٍ وَلَا كَرِيمٍ"},{"id":5024,"verse_key":"56:45","text_uthmani":"إِنَّهُمْ كَانُوا۟ قَبْلَ ذَٰلِكَ مُتْرَفِينَ"},{"id":5025,"verse_key":"56:46","text_uthmani":"وَكَانُوا۟ يُصِرُّونَ عَلَى ٱلْحِنثِ ٱلْعَظِيمِ"},{"id":5026,"verse_key":"56:47","text_uthmani":"وَكَانُوا۟ يَقُولُونَ أَئِذَا مِتْنَا وَكُنَّا تُرَابًا وَعِظَـٰمًا أَءِنَّا لَمَبْعُوثُونَ"},{"id":5027,"verse_key":"56:48","text_uthmani":"أَوَءَابَآؤُنَا ٱلْأَوَّلُونَ"},{"id":5028,"verse_key":"56:49","text_uthmani":"قُلْ إِنَّ ٱلْأَوَّلِينَ وَٱلْـَٔاخِرِينَ"},{"id":5029,"verse_key":"56:50","text_uthmani":"لَمَجْمُوعُونَ إِلَىٰ مِيقَـٰتِ يَوْمٍ مَّعْلُومٍ"}]