[{"id":3915,"verse_key":"37:127","text_uthmani":"فَكَذَّبُوهُ فَإِنَّهُمْ لَمُحْضَرُونَ"},{"id":3916,"verse_key":"37:128","text_uthmani":"إِلَّا عِبَادَ ٱللَّهِ ٱلْمُخْلَصِينَ"},{"id":3917,"verse_key":"37:129","text_uthmani":"وَتَرَكْنَا عَلَيْهِ فِى ٱلْـَٔاخِرِينَ"},{"id":3918,"verse_key":"37:130","text_uthmani":"سَلَـٰمٌ عَلَىٰٓ إِلْ يَاسِينَ"},{"id":3919,"verse_key":"37:131","text_uthmani":"إِنَّا كَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ"},{"id":3920,"verse_key":"37:132","text_uthmani":"إِنَّهُۥ مِنْ عِبَادِنَا ٱلْمُؤْمِنِينَ"},{"id":3921,"verse_key":"37:133","text_uthmani":"وَإِنَّ لُوطًا لَّمِنَ ٱلْمُرْسَلِينَ"},{"id":3922,"verse_key":"37:134","text_uthmani":"إِذْ نَجَّيْنَـٰهُ وَأَهْلَهُۥٓ أَجْمَعِينَ"},{"id":3923,"verse_key":"37:135","text_uthmani":"إِلَّا عَجُوزًا فِى ٱلْغَـٰبِرِينَ"},{"id":3924,"verse_key":"37:136","text_uthmani":"ثُمَّ دَمَّرْنَا ٱلْـَٔاخَرِينَ"},{"id":3925,"verse_key":"37:137","text_uthmani":"وَإِنَّكُمْ لَتَمُرُّونَ عَلَيْهِم مُّصْبِحِينَ"},{"id":3926,"verse_key":"37:138","text_uthmani":"وَبِٱلَّيْلِ ۗ أَفَلَا تَعْقِلُونَ"},{"id":3927,"verse_key":"37:139","text_uthmani":"وَإِنَّ يُونُسَ لَمِنَ ٱلْمُرْسَلِينَ"},{"id":3928,"verse_key":"37:140","text_uthmani":"إِذْ أَبَقَ إِلَى ٱلْفُلْكِ ٱلْمَشْحُونِ"},{"id":3929,"verse_key":"37:141","text_uthmani":"فَسَاهَمَ فَكَانَ مِنَ ٱلْمُدْحَضِينَ"},{"id":3930,"verse_key":"37:142","text_uthmani":"فَٱلْتَقَمَهُ ٱلْحُوتُ وَهُوَ مُلِيمٌ"},{"id":3931,"verse_key":"37:143","text_uthmani":"فَلَوْلَآ أَنَّهُۥ كَانَ مِنَ ٱلْمُسَبِّحِينَ"},{"id":3932,"verse_key":"37:144","text_uthmani":"لَلَبِثَ فِى بَطْنِهِۦٓ إِلَىٰ يَوْمِ يُبْعَثُونَ"},{"id":3933,"verse_key":"37:145","text_uthmani":"۞ فَنَبَذْنَـٰهُ بِٱلْعَرَآءِ وَهُوَ سَقِيمٌ"},{"id":3934,"verse_key":"37:146","text_uthmani":"وَأَنۢبَتْنَا عَلَيْهِ شَجَرَةً مِّن يَقْطِينٍ"},{"id":3935,"verse_key":"37:147","text_uthmani":"وَأَرْسَلْنَـٰهُ إِلَىٰ مِا۟ئَةِ أَلْفٍ أَوْ يَزِيدُونَ"},{"id":3936,"verse_key":"37:148","text_uthmani":"فَـَٔامَنُوا۟ فَمَتَّعْنَـٰهُمْ إِلَىٰ حِينٍ"},{"id":3937,"verse_key":"37:149","text_uthmani":"فَٱسْتَفْتِهِمْ أَلِرَبِّكَ ٱلْبَنَاتُ وَلَهُمُ ٱلْبَنُونَ"},{"id":3938,"verse_key":"37:150","text_uthmani":"أَمْ خَلَقْنَا ٱلْمَلَـٰٓئِكَةَ إِنَـٰثًا وَهُمْ شَـٰهِدُونَ"},{"id":3939,"verse_key":"37:151","text_uthmani":"أَلَآ إِنَّهُم مِّنْ إِفْكِهِمْ لَيَقُولُونَ"},{"id":3940,"verse_key":"37:152","text_uthmani":"وَلَدَ ٱللَّهُ وَإِنَّهُمْ لَكَـٰذِبُونَ"},{"id":3941,"verse_key":"37:153","text_uthmani":"أَصْطَفَى ٱلْبَنَاتِ عَلَى ٱلْبَنِينَ"}]