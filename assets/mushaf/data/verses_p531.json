[{"id":4896,"verse_key":"54:50","text_uthmani":"وَمَآ أَمْرُنَآ إِلَّا وَٰحِدَةٌ كَلَمْحٍۭ بِٱلْبَصَرِ"},{"id":4897,"verse_key":"54:51","text_uthmani":"وَلَقَدْ أَهْلَكْنَآ أَشْيَاعَكُمْ فَهَلْ مِن مُّدَّكِرٍ"},{"id":4898,"verse_key":"54:52","text_uthmani":"وَكُلُّ شَىْءٍ فَعَلُوهُ فِى ٱلزُّبُرِ"},{"id":4899,"verse_key":"54:53","text_uthmani":"وَكُلُّ صَغِيرٍ وَكَبِيرٍ مُّسْتَطَرٌ"},{"id":4900,"verse_key":"54:54","text_uthmani":"إِنَّ ٱلْمُتَّقِينَ فِى جَنَّـٰتٍ وَنَهَرٍ"},{"id":4901,"verse_key":"54:55","text_uthmani":"فِى مَقْعَدِ صِدْقٍ عِندَ مَلِيكٍ مُّقْتَدِرٍۭ"},{"id":4902,"verse_key":"55:1","text_uthmani":" ٱلرَّحْمَـٰنُ"},{"id":4903,"verse_key":"55:2","text_uthmani":"عَلَّمَ ٱلْقُرْءَانَ"},{"id":4904,"verse_key":"55:3","text_uthmani":"خَلَقَ ٱلْإِنسَـٰنَ"},{"id":4905,"verse_key":"55:4","text_uthmani":"عَلَّمَهُ ٱلْبَيَانَ"},{"id":4906,"verse_key":"55:5","text_uthmani":"ٱلشَّمْسُ وَٱلْقَمَرُ بِحُسْبَانٍ"},{"id":4907,"verse_key":"55:6","text_uthmani":"وَٱلنَّجْمُ وَٱلشَّجَرُ يَسْجُدَانِ"},{"id":4908,"verse_key":"55:7","text_uthmani":"وَٱلسَّمَآءَ رَفَعَهَا وَوَضَعَ ٱلْمِيزَانَ"},{"id":4909,"verse_key":"55:8","text_uthmani":"أَلَّا تَطْغَوْا۟ فِى ٱلْمِيزَانِ"},{"id":4910,"verse_key":"55:9","text_uthmani":"وَأَقِيمُوا۟ ٱلْوَزْنَ بِٱلْقِسْطِ وَلَا تُخْسِرُوا۟ ٱلْمِيزَانَ"},{"id":4911,"verse_key":"55:10","text_uthmani":"وَٱلْأَرْضَ وَضَعَهَا لِلْأَنَامِ"},{"id":4912,"verse_key":"55:11","text_uthmani":"فِيهَا فَـٰكِهَةٌ وَٱلنَّخْلُ ذَاتُ ٱلْأَكْمَامِ"},{"id":4913,"verse_key":"55:12","text_uthmani":"وَٱلْحَبُّ ذُو ٱلْعَصْفِ وَٱلرَّيْحَانُ"},{"id":4914,"verse_key":"55:13","text_uthmani":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"id":4915,"verse_key":"55:14","text_uthmani":"خَلَقَ ٱلْإِنسَـٰنَ مِن صَلْصَـٰلٍ كَٱلْفَخَّارِ"},{"id":4916,"verse_key":"55:15","text_uthmani":"وَخَلَقَ ٱلْجَآنَّ مِن مَّارِجٍ مِّن نَّارٍ"},{"id":4917,"verse_key":"55:16","text_uthmani":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"}]