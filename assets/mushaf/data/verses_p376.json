[{"id":3139,"verse_key":"26:207","text_uthmani":"مَآ أَغْنَىٰ عَنْهُم مَّا كَانُوا۟ يُمَتَّعُونَ"},{"id":3140,"verse_key":"26:208","text_uthmani":"وَمَآ أَهْلَكْنَا مِن قَرْيَةٍ إِلَّا لَهَا مُنذِرُونَ"},{"id":3141,"verse_key":"26:209","text_uthmani":"ذِكْرَىٰ وَمَا كُنَّا ظَـٰلِمِينَ"},{"id":3142,"verse_key":"26:210","text_uthmani":"وَمَا تَنَزَّلَتْ بِهِ ٱلشَّيَـٰطِينُ"},{"id":3143,"verse_key":"26:211","text_uthmani":"وَمَا يَنۢبَغِى لَهُمْ وَمَا يَسْتَطِيعُونَ"},{"id":3144,"verse_key":"26:212","text_uthmani":"إِنَّهُمْ عَنِ ٱلسَّمْعِ لَمَعْزُولُونَ"},{"id":3145,"verse_key":"26:213","text_uthmani":"فَلَا تَدْعُ مَعَ ٱللَّهِ إِلَـٰهًا ءَاخَرَ فَتَكُونَ مِنَ ٱلْمُعَذَّبِينَ"},{"id":3146,"verse_key":"26:214","text_uthmani":"وَأَنذِرْ عَشِيرَتَكَ ٱلْأَقْرَبِينَ"},{"id":3147,"verse_key":"26:215","text_uthmani":"وَٱخْفِضْ جَنَاحَكَ لِمَنِ ٱتَّبَعَكَ مِنَ ٱلْمُؤْمِنِينَ"},{"id":3148,"verse_key":"26:216","text_uthmani":"فَإِنْ عَصَوْكَ فَقُلْ إِنِّى بَرِىٓءٌ مِّمَّا تَعْمَلُونَ"},{"id":3149,"verse_key":"26:217","text_uthmani":"وَتَوَكَّلْ عَلَى ٱلْعَزِيزِ ٱلرَّحِيمِ"},{"id":3150,"verse_key":"26:218","text_uthmani":"ٱلَّذِى يَرَىٰكَ حِينَ تَقُومُ"},{"id":3151,"verse_key":"26:219","text_uthmani":"وَتَقَلُّبَكَ فِى ٱلسَّـٰجِدِينَ"},{"id":3152,"verse_key":"26:220","text_uthmani":"إِنَّهُۥ هُوَ ٱلسَّمِيعُ ٱلْعَلِيمُ"},{"id":3153,"verse_key":"26:221","text_uthmani":"هَلْ أُنَبِّئُكُمْ عَلَىٰ مَن تَنَزَّلُ ٱلشَّيَـٰطِينُ"},{"id":3154,"verse_key":"26:222","text_uthmani":"تَنَزَّلُ عَلَىٰ كُلِّ أَفَّاكٍ أَثِيمٍ"},{"id":3155,"verse_key":"26:223","text_uthmani":"يُلْقُونَ ٱلسَّمْعَ وَأَكْثَرُهُمْ كَـٰذِبُونَ"},{"id":3156,"verse_key":"26:224","text_uthmani":"وَٱلشُّعَرَآءُ يَتَّبِعُهُمُ ٱلْغَاوُۥنَ"},{"id":3157,"verse_key":"26:225","text_uthmani":"أَلَمْ تَرَ أَنَّهُمْ فِى كُلِّ وَادٍ يَهِيمُونَ"},{"id":3158,"verse_key":"26:226","text_uthmani":"وَأَنَّهُمْ يَقُولُونَ مَا لَا يَفْعَلُونَ"},{"id":3159,"verse_key":"26:227","text_uthmani":"إِلَّا ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ وَذَكَرُوا۟ ٱللَّهَ كَثِيرًا وَٱنتَصَرُوا۟ مِنۢ بَعْدِ مَا ظُلِمُوا۟ ۗ وَسَيَعْلَمُ ٱلَّذِينَ ظَلَمُوٓا۟ أَىَّ مُنقَلَبٍ يَنقَلِبُونَ"}]